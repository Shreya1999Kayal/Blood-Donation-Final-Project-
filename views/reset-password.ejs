<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Reset Password — RaktaSetu</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h3 class="text-center mb-3">Set new password</h3>

                        <% if (error) { %><div class="alert alert-danger py-2"><%= error %></div><% } %>

                        <% if (token) { %>
                            <form action="/auth/reset-password/<%= token %>" method="POST">
                                <div class="mb-3">
                                    <label>New password</label>
                                    <input type="password" name="password" class="form-control" minlength="6" required>
                                </div>
                                <div class="mb-3">
                                    <label>Confirm new password</label>
                                    <input type="password" name="confirmPassword" class="form-control" minlength="6" required>
                                </div>
                                <button type="submit" class="btn btn-danger w-100">Update password</button>
                            </form>
                        <% } else { %>
                            <p class="text-center"><a href="/auth/forgot-password">Request a new reset link</a></p>
                        <% } %>
                        <p class="text-center mt-3 mb-0"><a href="/auth/login">Back to login</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

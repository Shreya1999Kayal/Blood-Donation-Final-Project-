<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chat with <%= otherUser.name %> — RaktaSetu</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/admin-ui.css" rel="stylesheet">
    <link href="/css/bloodbank-ui.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/socket.io/socket.io.js"></script>
</head>
<body class="admin-shell bb-shell bb-chat-page">

<div class="bb-messages-topbar">
    <div class="container-fluid px-3 px-lg-4 d-flex align-items-center gap-3">
        <a href="/messages" class="btn btn-outline-danger btn-sm">
            <i data-lucide="arrow-left" style="width:14px;height:14px;"></i> Inbox
        </a>
        <div class="bb-chat-contact flex-grow-1">
            <%- include('partials/shared/card-avatar', { contactUser: otherUser, cardAvatarClass: 'bb-chat-contact-avatar' }) %>
            <div>
                <h1 class="bb-messages-page-title mb-0"><%= otherUser.name %></h1>
                <span class="bb-topbar-sub">
                    Patient · <%= otherUser.city || '—' %>
                    <% if (otherUser.phone) { %> · <a href="tel:<%= otherUser.phone %>" class="text-decoration-none"><%= otherUser.phone %></a><% } %>
                </span>
                <span id="chatPresenceStatus" class="chat-presence is-offline d-block mt-1">Offline</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <% if (otherUser.phone) { %>
            <a href="tel:<%= otherUser.phone %>" class="btn btn-danger btn-sm">
                <i data-lucide="phone-call" style="width:14px;height:14px;"></i> Call
            </a>
            <% } %>
            <a href="/dashboard#section-requests" class="btn btn-outline-danger btn-sm d-none d-md-inline-flex">
                <i data-lucide="siren" style="width:14px;height:14px;"></i> Requests
            </a>
        </div>
    </div>
</div>

<main class="bb-chat-main">
    <div class="container-fluid px-3 px-lg-4 py-4">
        <div class="row justify-content-center">
            <div class="col-xl-9 col-lg-10">
                <div class="overview-panel bb-chat-panel">
                    <div class="overview-panel-head flex-wrap">
                        <div>
                            <h5 class="mb-0">Secure conversation</h5>
                            <p class="text-muted small mb-0">Messages are delivered in real time. Confirm blood availability clearly for the patient.</p>
                        </div>
                        <span class="msg-live-pill"><span class="pulse-dot"></span> Live chat</span>
                    </div>
                    <div class="bb-chat-box" id="chatBox">
                        <% if (messages && messages.length) { %>
                            <% messages.forEach(function(m) { %>
                                <% const isMe = m.from.toString() === user._id.toString(); %>
                                <div class="bb-chat-row <%= isMe ? 'bb-chat-row-me' : 'bb-chat-row-them' %>">
                                    <% if (!isMe) { %>
                                    <%- include('partials/shared/card-avatar', { contactUser: otherUser, cardAvatarClass: 'bb-chat-mini-avatar' }) %>
                                    <% } %>
                                    <div class="bb-chat-bubble <%= isMe ? 'bb-chat-bubble-me' : 'bb-chat-bubble-them' %>">
                                        <div class="bb-chat-text"><%= m.text %></div>
                                        <time class="bb-chat-time"><%= new Date(m.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></time>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="bb-chat-empty">
                                <img src="https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=400&h=260&fit=crop&q=80" alt="" loading="lazy">
                                <h6>No messages yet</h6>
                                <p class="text-muted small mb-0">Introduce your hospital, confirm blood group availability, and share next steps.</p>
                            </div>
                        <% } %>
                    </div>
                    <div class="bb-chat-compose">
                        <form id="chatForm" class="bb-chat-form">
                            <input class="form-control" id="chatInput" placeholder="Type your message to the patient…" autocomplete="off" maxlength="2000" required>
                            <button class="btn btn-danger px-4" type="submit">
                                <i data-lucide="send" style="width:16px;height:16px;"></i> Send
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    window.__CHAT__ = {
        conversationId: "<%= conversation._id %>",
        otherUserId: "<%= otherUser._id %>",
        currentUserId: "<%= user._id %>",
        theme: 'bloodbank'
    };
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script src="/js/chat-presence.js"></script>
<script src="/js/chat.js"></script>
<script>if (typeof lucide !== 'undefined') lucide.createIcons();</script>
</body>
</html>

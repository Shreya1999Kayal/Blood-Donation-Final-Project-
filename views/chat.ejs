<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chat with <%= otherUser.name %> — RaktaSetu</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/admin-ui.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; background: #f8fafc; }
        .chat-box { height: 60vh; overflow-y: auto; background: #fff; }
        .msg { max-width: 75%; }
        .msg-me { background: #dc3545; color: #fff; }
        .msg-them { background: #f1f3f5; }
        .chat-header-avatar { width: 48px; height: 48px; border-radius: 14px; overflow: hidden; flex-shrink: 0; background: linear-gradient(135deg, #ef4444, #991b1b); color: #fff; font-weight: 800; display: flex; align-items: center; justify-content: center; }
        .chat-header-avatar .card-avatar-img { width: 100%; height: 100%; object-fit: cover; }
        .chat-header-avatar .card-avatar-text { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; }
        .chat-presence { display: inline-flex; align-items: center; gap: 6px; font-size: .78rem; font-weight: 600; }
        .chat-presence::before { content: ''; width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
        .chat-presence.is-online { color: #16a34a; }
        .chat-presence.is-online::before { background: #22c55e; box-shadow: 0 0 0 2px rgba(34, 197, 94, .25); }
        .chat-presence.is-offline { color: #64748b; }
        .chat-presence.is-offline::before { background: #94a3b8; }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-danger">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">🩸 RaktaSetu</a>
            <div class="collapse navbar-collapse justify-content-end">
                <span class="navbar-text text-white me-3 d-flex align-items-center gap-2">
                    <%- include('partials/shared/user-avatar', { user, avatarSize: 'sm' }) %>
                    <%= user.name %> (<%= user.role %>)
                </span>
                <a class="btn btn-light btn-sm me-2" href="/messages">💬 Messages</a>
                <a class="btn btn-outline-light btn-sm" href="/dashboard">Back</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-2 gap-3">
            <div class="d-flex align-items-center gap-3">
                <%- include('partials/shared/card-avatar', { contactUser: otherUser, cardAvatarClass: 'chat-header-avatar' }) %>
                <div>
                    <h4 class="mb-0">Chat with <%= otherUser.name %></h4>
                    <div class="text-muted small"><%= otherUser.role %> • <%= otherUser.city %></div>
                    <span id="chatPresenceStatus" class="chat-presence is-offline">Offline</span>
                </div>
            </div>
            <% if (otherUser.phone) { %>
                <a class="btn btn-outline-danger btn-sm" href="tel:<%= otherUser.phone %>">Call</a>
            <% } %>
        </div>

        <div class="border rounded chat-box p-3" id="chatBox">
            <% if (messages && messages.length) { %>
                <% messages.forEach(function(m) { %>
                    <% const isMe = m.from.toString() === user._id.toString(); %>
                    <div class="d-flex mb-2 <%= isMe ? 'justify-content-end' : 'justify-content-start' %>">
                        <div class="msg rounded px-3 py-2 <%= isMe ? 'msg-me' : 'msg-them' %>">
                            <div class="small" style="white-space: pre-wrap;"><%= m.text %></div>
                            <div class="text-end" style="font-size: 0.7rem; opacity: 0.8;">
                                <%= new Date(m.createdAt).toLocaleTimeString() %>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="text-muted small">No messages yet. Say hi.</div>
            <% } %>
        </div>

        <form class="mt-3 d-flex gap-2" id="chatForm">
            <input class="form-control" id="chatInput" placeholder="Type a message..." autocomplete="off" maxlength="2000" required>
            <button class="btn btn-danger" type="submit">Send</button>
        </form>
    </div>

    <script>
        window.__CHAT__ = {
            conversationId: "<%= conversation._id %>",
            otherUserId: "<%= otherUser._id %>",
            currentUserId: "<%= user._id %>"
        };
    </script>
    <script src="/js/chat-presence.js"></script>
    <script src="/js/chat.js"></script>
</body>
</html>

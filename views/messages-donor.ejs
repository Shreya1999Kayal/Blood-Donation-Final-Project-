<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Messages — RaktaSetu Donor</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/admin-ui.css" rel="stylesheet">
    <link href="/css/donor-ui.css" rel="stylesheet">
    <%- include('partials/donor/tailwind-head') %>
    <script src="/socket.io/socket.io.js"></script>
</head>
<body class="admin-shell dn-shell">

<div class="admin-overlay" id="dnOverlay"></div>

<%- include('partials/donor/sidebar', { user, bloodRequests: bloodRequests || [], inbox, notifications: [], donorProfile }) %>

<div class="admin-main">
    <header class="admin-topbar">
        <button type="button" class="admin-hamburger" id="dnHamburger" aria-label="Menu">
            <i data-lucide="menu" style="width:20px;height:20px;"></i>
        </button>
        <div class="admin-topbar-title-wrap">
            <h2 id="dnPageTitle">Messages</h2>
            <span class="dn-topbar-sub">Full inbox · patients only</span>
        </div>
        <div class="ms-auto d-flex align-items-center gap-2">
            <a href="/dashboard" class="btn btn-outline-success btn-sm">← Dashboard</a>
        </div>
    </header>

    <main class="admin-content">
        <%- include('partials/donor/section-messages', { user, inbox, isFullPage: true }) %>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script src="/js/donor-ui.js"></script>
</body>
</html>

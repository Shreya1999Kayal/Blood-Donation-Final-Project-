<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Emergency Requests — RaktaSetu</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-danger">
        <div class="container">
            <a class="navbar-brand" href="/">🩸 RaktaSetu</a>
            <div class="collapse navbar-collapse justify-content-end">
                <a class="nav-link text-white me-3" href="/dashboard">Back to Dashboard</a>
                <% if (['user', 'donor', 'bloodbank'].includes(user.role)) { %>
                    <a class="btn btn-light btn-sm me-2" href="/messages">💬 Messages</a>
                <% } %>
                <a class="btn btn-outline-light btn-sm" href="/auth/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <h2 class="mb-4">Live Emergency Blood Requests</h2>
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white"><h5 class="mb-0">Live notifications</h5></div>
            <div class="list-group list-group-flush" id="notificationList">
                <% if (notifications && notifications.length) { %>
                    <% notifications.forEach(function(n) { %>
                        <a href="<%= n.link || '/dashboard' %>" class="list-group-item list-group-item-action">
                            <div class="d-flex justify-content-between">
                                <strong><%= n.title %></strong>
                                <small class="text-muted"><%= new Date(n.createdAt).toLocaleTimeString() %></small>
                            </div>
                            <div class="small"><%= n.message %></div>
                        </a>
                    <% }); %>
                <% } else { %>
                    <div class="list-group-item text-muted small">Listening in <%= user.city %>...</div>
                <% } %>
            </div>
        </div>
        <%- include('partials/blood-requests-table', { bloodRequests: requests, user, donorProfile, bloodbank }) %>
    </div>
    <script>
        const socket = io();
        const currentUser = { id: "<%= user._id %>", role: "<%= user.role %>", city: "<%= user.city %>" };
        socket.emit('join_city', currentUser.city);
        socket.emit('join_context', currentUser);

        function pushNotification(html, cssClass) {
            const list = document.getElementById('notificationList');
            if (!list) return;
            const item = document.createElement('div');
            item.className = 'list-group-item ' + (cssClass || 'list-group-item-info');
            item.innerHTML = html;
            const placeholder = list.querySelector('.text-muted');
            if (placeholder) placeholder.remove();
            list.prepend(item);
        }

        socket.on('notification:new', (data) => {
            const notificationUserId = data.userId ? data.userId.toString() : null;
            const forUser = notificationUserId === currentUser.id;
            const roleMatch = Array.isArray(data.roles) && data.roles.includes(currentUser.role);
            const cityMatch = data.city && data.city.toLowerCase() === currentUser.city.toLowerCase();
            const broadcast = !notificationUserId && (!data.roles || data.roles.length === 0) && !data.city;
            if (!(forUser || roleMatch || cityMatch || broadcast)) return;

            const time = data.createdAt ? new Date(data.createdAt).toLocaleTimeString() : new Date().toLocaleTimeString();
            const link = data.link || '/dashboard';
            const cssClass = data.type === 'request' ? 'list-group-item-danger' : data.type === 'approval' ? 'list-group-item-success' : 'list-group-item-info';
            pushNotification(`<a class="text-decoration-none text-dark" href="${link}"><div class="d-flex justify-content-between"><strong>${data.title}</strong><small class="text-muted">${time}</small></div><div class="small">${data.message}</div></a>`, cssClass);
        });
    </script>
</body>
</html>

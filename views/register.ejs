<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register — RaktaSetu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/home.css" rel="stylesheet">
    <link href="/css/auth-pages.css?v=2" rel="stylesheet">
    <link href="/css/admin-ui.css" rel="stylesheet">
    <%- include('partials/home/tailwind-head') %>
    <style>
        .profile-photo-row { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
        .profile-photo-preview { width: 88px; height: 88px; border-radius: 20px; overflow: hidden; background: linear-gradient(135deg, #ef4444, #b91c1c); display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 24px rgba(220, 38, 38, 0.25); }
        .profile-photo-preview-img { width: 100%; height: 100%; object-fit: cover; }
        .profile-photo-preview-initial { color: #fff; font-weight: 800; font-size: 1.5rem; }
        .profile-photo-hint { font-size: 0.78rem; color: #64748b; margin-top: 0.45rem; }
    </style>
</head>
<body>
<div class="auth-page-shell home-shell min-h-screen">
    <%- include('partials/home/topbar', { user: typeof user !== 'undefined' ? user : null }) %>
    <nav class="auth-mini-nav home-subnav" aria-label="Quick links">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center gap-1 overflow-x-auto">
                <a href="/" class="home-subnav-link">Home</a>
                <a href="/auth/login" class="home-subnav-link">Login</a>
                <a href="/auth/register" class="home-subnav-link active">Register</a>
                <a href="/#find-blood" class="home-subnav-link">Find Blood</a>
            </div>
        </div>
    </nav>

    <div class="auth-page-bg">
        <div class="auth-card auth-card-wide">
            <div class="auth-card-head">
                <span class="auth-brand-pill">Join RaktaSetu</span>
                <h1 class="mt-3">Create your account</h1>
                <p>Step 1: SMS code · Step 2: email verification</p>
            </div>
            <div class="auth-card-body">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger py-2"><%= error %></div>
                <% } %>
                <form action="/auth/register" method="POST" enctype="multipart/form-data" id="registerForm">
                    <%- include('partials/shared/profile-photo-field', { user: { name: '', profileImage: {} }, photoFieldPrefix: 'register', photoHint: 'Optional now — you can change it later in your profile' }) %>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input type="text" name="name" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" name="email" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Password</label>
                            <input type="password" name="password" class="form-control" minlength="6" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phone</label>
                            <input type="tel" name="phone" class="form-control" pattern="[6-9][0-9]{9}" placeholder="e.g. 9876543210" minlength="10" maxlength="10" inputmode="numeric" required>
                            <div class="form-text">10-digit Indian mobile starting with 6, 7, 8, or 9</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">City</label>
                            <input type="text" name="city" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Role</label>
                            <select name="role" class="form-select" id="registerRole">
                                <option value="user" <%= (typeof defaultRole !== 'undefined' && defaultRole === 'user') ? 'selected' : '' %>>User / Patient</option>
                                <option value="donor" <%= (typeof defaultRole !== 'undefined' && defaultRole === 'donor') ? 'selected' : '' %>>Blood Donor</option>
                                <option value="bloodbank" <%= (typeof defaultRole !== 'undefined' && defaultRole === 'bloodbank') ? 'selected' : '' %>>Blood Bank</option>
                                <option value="camp" <%= (typeof defaultRole !== 'undefined' && defaultRole === 'camp') ? 'selected' : '' %>>Blood Donation Camp</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-brand w-100 mt-4">Create account</button>
                </form>
                <p class="text-center mt-3 mb-0">Already have an account? <a href="/auth/login">Login</a></p>
            </div>
        </div>
    </div>
</div>
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script src="/js/profile-photo-preview.js"></script>
<script>if (typeof lucide !== 'undefined') lucide.createIcons();</script>
<%- include('partials/shared/help-chatbot', { user: typeof user !== 'undefined' ? user : null }) %>
</body>
</html>

<%
const history = donationHistory || [];
const totalUnits = history.reduce(function(sum, item) { return sum + Number(item.units || 0); }, 0);
const hospitals = new Set(history.map(function(item) { return item.hospitalName; }).filter(Boolean)).size;
%>

<div class="overview-panel dn-donation-registry">
    <div class="overview-panel-head flex-wrap gap-3">
        <div class="d-flex align-items-start gap-3 flex-grow-1">
            <div class="dn-donation-registry-icon" aria-hidden="true">
                <i data-lucide="heart-handshake" style="width:22px;height:22px;"></i>
            </div>
            <div>
                <h5 class="mb-1">Donation history registry</h5>
                <p class="text-muted small mb-0">Every unit you donated through RaktaSetu — hospital, patient case, blood group, and date.</p>
            </div>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="dn-donation-stat-pill">
                <i data-lucide="clipboard-list" style="width:14px;height:14px;"></i>
                <%= history.length %> donation<%= history.length !== 1 ? 's' : '' %>
            </span>
            <% if (history.length) { %>
            <span class="dn-donation-stat-pill dn-donation-stat-pill--units">
                <i data-lucide="droplets" style="width:14px;height:14px;"></i>
                <%= totalUnits %> units
            </span>
            <% if (hospitals) { %>
            <span class="dn-donation-stat-pill dn-donation-stat-pill--hospitals">
                <i data-lucide="building-2" style="width:14px;height:14px;"></i>
                <%= hospitals %> hospital<%= hospitals !== 1 ? 's' : '' %>
            </span>
            <% } %>
            <% } %>
        </div>
    </div>

    <div class="overview-panel-body p-0">
        <% if (history.length) { %>
        <div class="dn-donation-search-wrap px-3 px-md-4 pt-3 pb-2 border-bottom bg-light-subtle">
            <div class="dn-donation-search">
                <i data-lucide="search" style="width:16px;height:16px;"></i>
                <input type="search" id="dnDonationSearch" class="form-control form-control-sm" placeholder="Search hospital, patient, blood group…" autocomplete="off">
            </div>
        </div>

        <div class="table-responsive dn-donation-table-wrap">
            <table class="table dn-donation-table align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Donated on</th>
                        <th scope="col">Hospital</th>
                        <th scope="col">Patient case</th>
                        <th scope="col">Blood group</th>
                        <th scope="col" class="text-center">Units</th>
                    </tr>
                </thead>
                <tbody id="dnDonationTableBody">
                    <% history.forEach(function(item) {
                        const req = item.requestId || {};
                        const patientLabel = req.patientName
                            ? req.patientName + (req.city ? ' · ' + req.city : '')
                            : '';
                        const searchText = [item.hospitalName, patientLabel, req.city, item.bloodGroup].filter(Boolean).join(' ').toLowerCase();
                    %>
                    <tr class="dn-donation-row" data-donation-search="<%= searchText.replace(/"/g, '') %>">
                        <td data-label="Donated on">
                            <div class="dn-donation-date">
                                <span class="dn-donation-date-icon"><i data-lucide="calendar" style="width:14px;height:14px;"></i></span>
                                <div>
                                    <strong><%= new Date(item.donatedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></strong>
                                    <small><%= new Date(item.donatedAt).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %></small>
                                </div>
                            </div>
                        </td>
                        <td data-label="Hospital">
                            <div class="dn-donation-hospital">
                                <span class="dn-donation-hospital-icon"><i data-lucide="building-2" style="width:14px;height:14px;"></i></span>
                                <strong><%= item.hospitalName || '—' %></strong>
                            </div>
                        </td>
                        <td data-label="Patient case">
                            <% if (patientLabel) { %>
                            <span class="dn-donation-case"><%= patientLabel %></span>
                            <% } else { %>
                            <span class="text-muted">—</span>
                            <% } %>
                        </td>
                        <td data-label="Blood group">
                            <span class="overview-blood-badge dn-donation-blood"><%= item.bloodGroup %></span>
                        </td>
                        <td data-label="Units" class="text-center">
                            <span class="dn-donation-units"><%= item.units %><small>unit<%= Number(item.units) !== 1 ? 's' : '' %></small></span>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>

        <div id="dnDonationEmptyFilter" class="dn-donation-empty-filter d-none">
            <i data-lucide="filter-x" style="width:28px;height:28px;"></i>
            <p class="mb-2 fw-semibold">No donations match your search</p>
            <button type="button" class="btn btn-sm btn-outline-danger" id="dnDonationClearSearch">Clear search</button>
        </div>
        <% } else { %>
        <div class="dn-donation-empty">
            <div class="dn-donation-empty-icon">
                <i data-lucide="history" style="width:32px;height:32px;"></i>
            </div>
            <h6>No donation history yet</h6>
            <p class="text-muted small mb-0">When you fulfill an emergency request, each donation is logged here automatically with hospital and patient details.</p>
        </div>
        <% } %>
    </div>
</div>

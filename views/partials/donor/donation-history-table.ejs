<%
function dnThClass() {
    return 'px-4 py-3.5 text-left text-[11px] font-semibold uppercase tracking-wider text-slate-500 whitespace-nowrap';
}
function dnTdClass() {
    return 'px-4 py-3.5 align-middle text-slate-700';
}
function dnRowClass() {
    return 'transition-colors hover:bg-emerald-50/40 group';
}
function dnBadgeBase() {
    return 'inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold ring-1 ring-inset';
}
function dnBloodTw() {
    return dnBadgeBase() + ' bg-rose-50 text-rose-700 ring-rose-600/20';
}
const history = donationHistory || [];
%>

<div class="overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-sm ring-1 ring-slate-900/5">
    <div class="flex items-center justify-between border-b border-slate-100 bg-gradient-to-r from-emerald-50/80 via-white to-slate-50/50 px-4 py-3">
        <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-slate-500">
            <span class="inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
            Donation history registry
        </div>
        <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-[11px] font-semibold text-slate-600"><%= history.length %> record<%= history.length !== 1 ? 's' : '' %></span>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-gradient-to-r from-emerald-50 via-slate-50 to-white">
                <tr>
                    <th class="<%= dnThClass() %>">Date</th>
                    <th class="<%= dnThClass() %>">Hospital</th>
                    <th class="<%= dnThClass() %>">Patient case</th>
                    <th class="<%= dnThClass() %>">Blood</th>
                    <th class="<%= dnThClass() %> text-right">Units</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
                <% if (history.length) { %>
                    <% history.forEach(function(item) { %>
                    <tr class="<%= dnRowClass() %>">
                        <td class="<%= dnTdClass() %> whitespace-nowrap">
                            <div class="font-semibold text-slate-900"><%= new Date(item.donatedAt).toLocaleDateString() %></div>
                            <div class="text-xs text-slate-500"><%= new Date(item.donatedAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></div>
                        </td>
                        <td class="<%= dnTdClass() %>">
                            <span class="font-medium text-slate-900"><%= item.hospitalName || '—' %></span>
                        </td>
                        <td class="<%= dnTdClass() %> text-slate-600">
                            <% if (item.requestId && item.requestId.patientName) { %>
                            <%= item.requestId.patientName %><% if (item.requestId.city) { %> · <%= item.requestId.city %><% } %>
                            <% } else { %>
                            <span class="text-slate-400">—</span>
                            <% } %>
                        </td>
                        <td class="<%= dnTdClass() %> whitespace-nowrap">
                            <span class="<%= dnBloodTw() %>"><%= item.bloodGroup %></span>
                        </td>
                        <td class="<%= dnTdClass() %> text-right whitespace-nowrap">
                            <span class="inline-flex h-8 min-w-[2rem] items-center justify-center rounded-lg bg-emerald-50 px-2 text-sm font-bold text-emerald-800 ring-1 ring-emerald-600/10"><%= item.units %></span>
                        </td>
                    </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="px-4 py-14 text-center">
                            <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-slate-400">
                                <i data-lucide="history" style="width:22px;height:22px;"></i>
                            </div>
                            <p class="text-sm font-medium text-slate-700">No donation history yet</p>
                            <p class="text-xs text-slate-500">When you fulfill an emergency request, donations are logged here automatically.</p>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

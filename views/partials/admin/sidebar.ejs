<%
const pendingDonors = (analytics && analytics.donorsByStatus && analytics.donorsByStatus.pending) || 0;
const pendingBanks = (allBloodBanks || []).filter(function(b) { return b.status === 'pending'; }).length;
const pendingCamps = (typeof allCamps !== 'undefined' ? allCamps : []).filter(function(c) { return c.status === 'pending'; }).length;
const pendingTotal = pendingDonors + pendingBanks + pendingCamps;
const activeRequests = (bloodRequests || []).filter(function(r) { return ['active', 'contacted'].includes(r.status); }).length;
%>
<aside class="admin-sidebar" id="adminSidebar">
    <div class="admin-sidebar-brand">
        <div class="d-flex align-items-start gap-3">
            <div class="logo"><i data-lucide="droplets" style="width:22px;height:22px;color:#fff;"></i></div>
            <div>
                <h1>RaktaSetu</h1>
                <p class="admin-portal-subtitle">Platform administration</p>
                <span class="admin-portal-tag">Admin</span>
            </div>
        </div>
    </div>

    <nav class="admin-nav">
        <a href="#" class="admin-nav-link active" data-admin-section="overview" data-admin-label="Overview">
            <i data-lucide="layout-dashboard" style="width:18px;height:18px;"></i> Overview
        </a>
        <a href="#" class="admin-nav-link" data-admin-section="requests" data-admin-label="Emergency Requests">
            <i data-lucide="siren" style="width:18px;height:18px;"></i> Emergency Requests
            <% if (activeRequests > 0) { %><span class="badge-count"><%= activeRequests %></span><% } %>
        </a>
        <a href="#" class="admin-nav-link" data-admin-section="donors" data-admin-label="Donor Management">
            <i data-lucide="heart-handshake" style="width:18px;height:18px;"></i> Donors
            <% if (pendingDonors > 0) { %><span class="badge-count"><%= pendingDonors %></span><% } %>
        </a>
        <a href="#" class="admin-nav-link" data-admin-section="bloodbanks" data-admin-label="Blood Banks">
            <i data-lucide="building-2" style="width:18px;height:18px;"></i> Blood Banks
            <% if (pendingBanks > 0) { %><span class="badge-count"><%= pendingBanks %></span><% } %>
        </a>
        <a href="#" class="admin-nav-link" data-admin-section="camps" data-admin-label="Camp Organizations">
            <i data-lucide="tent" style="width:18px;height:18px;"></i> Camps
            <% if (pendingCamps > 0) { %><span class="badge-count"><%= pendingCamps %></span><% } %>
        </a>
        <a href="#" class="admin-nav-link" data-admin-section="patients" data-admin-label="Patients">
            <i data-lucide="users" style="width:18px;height:18px;"></i> Patients
        </a>
        <a href="#" class="admin-nav-link" data-admin-section="notifications" data-admin-label="Notifications">
            <i data-lucide="bell" style="width:18px;height:18px;"></i> Notifications
        </a>
        <a href="#" class="admin-nav-link" data-admin-section="feedback" data-admin-label="Feedback">
            <i data-lucide="message-square-heart" style="width:18px;height:18px;"></i> Feedback
            <% if ((feedbackStats && feedbackStats.pending) > 0) { %><span class="badge-count"><%= feedbackStats.pending %></span><% } %>
        </a>
        <a href="#" class="admin-nav-link" data-admin-section="profile" data-admin-label="Profile">
            <i data-lucide="user-circle" style="width:18px;height:18px;"></i> Profile
        </a>
        <hr style="border-color: var(--adm-border); margin: 0.75rem 0;">
        <a href="#" class="admin-nav-link" data-admin-section="password" data-admin-label="Change Password">
            <i data-lucide="key-round" style="width:18px;height:18px;"></i> Change Password
        </a>
        <a href="/auth/logout" class="admin-nav-link text-danger">
            <i data-lucide="log-out" style="width:18px;height:18px;"></i> Logout
        </a>
    </nav>

    <div class="admin-sidebar-footer">
        <div class="admin-profile">
            <%- include('../shared/user-avatar', { user, avatarSize: 'sm' }) %>
            <div class="overflow-hidden">
                <div class="small fw-semibold text-truncate"><%= user.name %></div>
                <div style="font-size:0.65rem;color:var(--adm-muted);">System Administrator</div>
            </div>
        </div>
    </div>
</aside>

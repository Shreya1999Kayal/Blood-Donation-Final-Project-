<div class="overview-panel">
    <div class="overview-panel-head flex-wrap gap-2">
        <div>
            <h5>Camp organizations</h5>
            <p class="text-muted small mb-0">Manage blood donation camp organizers</p>
        </div>
        <div class="ms-auto d-flex align-items-center gap-2">
            <span class="badge bg-secondary"><%= (allCamps || []).length %> total</span>
            <button type="button" class="btn btn-danger btn-sm" data-admin-create="camp"><i data-lucide="plus" style="width:14px;height:14px;"></i> Add camp</button>
        </div>
    </div>
    <div class="overview-panel-body pt-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Organization</th>
                        <th>Organizer</th>
                        <th>City</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% (allCamps || []).forEach(function(c) {
                        const u = c.userId || {};
                    %>
                    <tr>
                        <td>
                            <strong><%= c.organizationName %></strong><br>
                            <small class="text-muted"><%= c.organizationType %></small>
                        </td>
                        <td>
                            <%= c.organizerName %><br>
                            <small><%= c.organizerMobile %> · <%= c.organizerEmail %></small>
                        </td>
                        <td><%= u.city || '—' %></td>
                        <td>
                            <span class="badge <%= c.status === 'approved' ? 'bg-success' : c.status === 'rejected' ? 'bg-danger' : 'bg-warning text-dark' %> text-capitalize">
                                <%= c.status.replace(/_/g, ' ') %>
                            </span>
                        </td>
                        <td class="text-end text-nowrap">
                            <div class="d-inline-flex flex-wrap gap-1 justify-content-end align-items-center">
                                <% if (c.status === 'pending' || c.status === 'pending_verification') { %>
                                <form action="/admin/camp/<%= c._id %>/approve" method="POST" class="d-inline"><button class="btn btn-sm btn-success">Approve</button></form>
                                <% } %>
                                <% if (c.status !== 'rejected') { %>
                                <form action="/admin/camp/<%= c._id %>/reject" method="POST" class="d-inline"><button class="btn btn-sm btn-outline-danger">Reject</button></form>
                                <% } %>
                                <%- include('admin-crud-actions', {
                                    entity: 'camp',
                                    payloadObj: {
                                        id: c._id,
                                        organizationName: c.organizationName,
                                        organizationType: c.organizationType,
                                        name: u.name || '',
                                        email: u.email || '',
                                        phone: u.phone || '',
                                        city: u.city || '',
                                        organizerName: c.organizerName,
                                        organizerMobile: c.organizerMobile,
                                        organizerEmail: c.organizerEmail,
                                        coOrganizerName: c.coOrganizerName || '',
                                        coOrganizerMobile: c.coOrganizerMobile || '',
                                        status: c.status,
                                        emailVerified: u.emailVerified,
                                        mobileVerified: c.mobileVerified
                                    },
                                    deleteUrl: '/admin/camp/' + c._id + '/delete',
                                    confirmLabel: c.organizationName || 'this camp'
                                }) %>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                    <% if (!(allCamps || []).length) { %>
                    <tr><td colspan="5" class="text-center text-muted py-4">No camp registrations yet.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

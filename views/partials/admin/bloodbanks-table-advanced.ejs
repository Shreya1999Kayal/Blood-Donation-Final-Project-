<%
function twBadgeBase() {
    return 'inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold ring-1 ring-inset';
}
function twStatusTw(status) {
    const map = {
        approved: 'bg-emerald-50 text-emerald-800 ring-emerald-600/20',
        rejected: 'bg-rose-50 text-rose-800 ring-rose-600/20',
        pending: 'bg-amber-50 text-amber-800 ring-amber-600/20',
    };
    return twBadgeBase() + ' ' + (map[status] || map.pending);
}
function twStockTw(stock, units) {
    if (stock === 'empty') return twBadgeBase() + ' bg-slate-100 text-slate-600 ring-slate-500/20';
    if (stock === 'low') return twBadgeBase() + ' bg-amber-50 text-amber-800 ring-amber-600/20';
    return twBadgeBase() + ' bg-emerald-50 text-emerald-800 ring-emerald-600/20';
}
function twThClass() {
    return 'px-4 py-3.5 text-left text-[11px] font-semibold uppercase tracking-wider text-slate-500 whitespace-nowrap';
}
function twTdClass() {
    return 'px-4 py-3.5 align-middle text-slate-700';
}
function twRowClass() {
    return 'transition-colors hover:bg-slate-50/90';
}
const banks = allBloodBanks || [];
%>

<div class="overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-sm ring-1 ring-slate-900/5">
    <div class="flex items-center justify-between border-b border-slate-100 bg-gradient-to-r from-rose-50/80 via-white to-slate-50/50 px-4 py-3">
        <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Hospital & blood bank registry</span>
        <span class="rounded-full bg-sky-50 px-2.5 py-0.5 text-[11px] font-semibold text-sky-800 ring-1 ring-sky-600/20"><%= banks.length %> hospitals</span>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-gradient-to-r from-rose-50 via-slate-50 to-white">
                <tr>
                    <th class="<%= twThClass() %>">Hospital</th>
                    <th class="<%= twThClass() %>">Contact</th>
                    <th class="<%= twThClass() %>">City</th>
                    <th class="<%= twThClass() %>">Status</th>
                    <th class="<%= twThClass() %>">Stock</th>
                    <th class="<%= twThClass() %>">Certificate</th>
                    <th class="<%= twThClass() %> text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
                <% if (banks.length) { %>
                    <% banks.forEach(function(bb) {
                        const u = bb.userId || {};
                        const searchText = [bb.hospitalName, u.name, u.email, u.phone, u.city].filter(Boolean).join(' ').toLowerCase();
                        const stock = stockKey(bb);
                        const units = totalInventory(bb);
                    %>
                    <tr class="<%= twRowClass() %>" data-bb-item data-status="<%= bb.status %>" data-stock="<%= stock %>" data-search="<%= searchText.replace(/"/g, '') %>">
                        <td class="<%= twTdClass() %> whitespace-nowrap">
                            <span class="font-semibold text-slate-900"><%= bb.hospitalName %></span>
                        </td>
                        <td class="<%= twTdClass() %> whitespace-nowrap">
                            <div class="font-medium text-slate-900"><%= u.name || '—' %></div>
                            <div class="text-xs text-slate-500"><%= u.phone || '' %></div>
                        </td>
                        <td class="<%= twTdClass() %> whitespace-nowrap text-slate-600"><%= u.city || '—' %></td>
                        <td class="<%= twTdClass() %>"><span class="<%= twStatusTw(bb.status) %>"><%= bb.status %></span></td>
                        <td class="<%= twTdClass() %>"><span class="<%= twStockTw(stock, units) %>"><%= stock === 'low' ? 'Low stock · ' : stock === 'empty' ? 'Empty · ' : '' %><%= units %> units</span></td>
                        <td class="<%= twTdClass() %> text-xs whitespace-nowrap">
                            <% if (bb.registrationCertificateUrl) { %>
                                <a href="<%= docUrl(bb.registrationCertificateUrl) %>" target="_blank" class="font-medium text-sky-700 hover:text-sky-900">View certificate</a>
                            <% } else { %><span class="text-amber-600 font-medium">Not uploaded</span><% } %>
                        </td>
                        <td class="<%= twTdClass() %> text-right whitespace-nowrap">
                            <div class="flex flex-wrap justify-end gap-1">
                                <% if (bb.status !== 'approved') { %>
                                    <form action="/admin/bloodbank/<%= bb._id %>/approve" method="POST">
                                        <button class="rounded-lg bg-emerald-600 px-2.5 py-1 text-xs font-semibold text-white hover:bg-emerald-700 disabled:opacity-50" <%= bb.registrationCertificateUrl ? '' : 'disabled title="Certificate required"' %>>Approve</button>
                                    </form>
                                <% } %>
                                <% if (bb.status !== 'rejected') { %>
                                    <form action="/admin/bloodbank/<%= bb._id %>/reject" method="POST">
                                        <button class="rounded-lg border border-rose-200 px-2.5 py-1 text-xs font-semibold text-rose-700 hover:bg-rose-50">Reject</button>
                                    </form>
                                <% } %>
                                <%- include('admin-crud-actions', {
                                    entity: 'bloodbank',
                                    payloadObj: {
                                        id: bb._id,
                                        hospitalName: bb.hospitalName,
                                        name: u.name || '',
                                        email: u.email || '',
                                        phone: u.phone || '',
                                        city: u.city || '',
                                        status: bb.status,
                                        emailVerified: u.emailVerified,
                                        registrationCertificateUrl: bb.registrationCertificateUrl || '',
                                        inventory: bb.inventory || {},
                                        coords: bb.location && bb.location.coordinates ? bb.location.coordinates : null
                                    },
                                    deleteUrl: '/admin/bloodbank/' + bb._id + '/delete',
                                    confirmLabel: bb.hospitalName || 'this blood bank'
                                }) %>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                <% } else { %>
                    <tr><td colspan="7" class="px-4 py-12 text-center text-sm text-slate-500">No blood banks registered</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

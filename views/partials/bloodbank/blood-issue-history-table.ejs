<%
function bbInitials(name) {
    if (!name) return '?';
    return name.split(' ').map(function(p) { return p[0]; }).slice(0, 2).join('').toUpperCase();
}
const history = bloodIssueHistory || [];
%>

<div class="overview-panel bb-issue-registry">
    <div class="overview-panel-head flex-wrap gap-3">
        <div class="d-flex align-items-start gap-3 flex-grow-1">
            <div class="bb-issue-registry-icon" aria-hidden="true">
                <i data-lucide="droplets" style="width:22px;height:22px;"></i>
            </div>
            <div>
                <h5 class="mb-1">Blood issued to patients</h5>
                <p class="text-muted small mb-0">Complete log of units supplied when patients mark your blood bank as the source.</p>
            </div>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="bb-issue-stat-pill">
                <i data-lucide="clipboard-list" style="width:14px;height:14px;"></i>
                <%= history.length %> record<%= history.length !== 1 ? 's' : '' %>
            </span>
            <% if (history.length) { %>
            <span class="bb-issue-stat-pill bb-issue-stat-pill--units">
                <i data-lucide="flask-conical" style="width:14px;height:14px;"></i>
                <%= history.reduce(function(s, i) { return s + Number(i.units || 0); }, 0) %> units issued
            </span>
            <% } %>
        </div>
    </div>

    <div class="overview-panel-body p-0">
        <% if (history.length) { %>
        <div class="bb-issue-search-wrap px-3 px-md-4 pt-3 pb-2 border-bottom bg-light-subtle">
            <div class="bb-issue-search">
                <i data-lucide="search" style="width:16px;height:16px;"></i>
                <input type="search" id="bbIssueSearch" class="form-control form-control-sm" placeholder="Search patient, hospital, city, blood group…" autocomplete="off">
            </div>
        </div>

        <div class="table-responsive bb-issue-table-wrap">
            <table class="table bb-issue-table align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Issued on</th>
                        <th scope="col">Patient</th>
                        <th scope="col">Hospital &amp; location</th>
                        <th scope="col">Blood group</th>
                        <th scope="col" class="text-center">Units</th>
                        <th scope="col" class="text-end">Inventory impact</th>
                    </tr>
                </thead>
                <tbody id="bbIssueTableBody">
                    <% history.forEach(function(item, index) {
                        const patient = item.patientUserId || {};
                        const patientName = patient.name || item.patientName || 'Patient';
                        const issuedDate = item.issuedAt || item.createdAt;
                        const prev = item.previousStock != null ? Number(item.previousStock) : null;
                        const remaining = item.remainingStock != null ? Number(item.remainingStock) : null;
                        const searchText = [patientName, patient.phone, item.hospitalName, item.city, patient.city, item.bloodGroup].filter(Boolean).join(' ').toLowerCase();
                    %>
                    <tr class="bb-issue-row" data-issue-search="<%= searchText.replace(/"/g, '') %>">
                        <td data-label="Issued on">
                            <div class="bb-issue-date">
                                <span class="bb-issue-date-icon"><i data-lucide="calendar" style="width:14px;height:14px;"></i></span>
                                <div>
                                    <strong><%= new Date(issuedDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></strong>
                                    <small><%= new Date(issuedDate).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %></small>
                                </div>
                            </div>
                        </td>
                        <td data-label="Patient">
                            <div class="bb-issue-patient">
                                <span class="bb-issue-avatar"><%= bbInitials(patientName) %></span>
                                <div>
                                    <strong class="bb-issue-patient-name"><%= patientName %></strong>
                                    <% if (patient.phone) { %>
                                    <a href="tel:<%= patient.phone %>" class="bb-issue-phone"><i data-lucide="phone" style="width:12px;height:12px;"></i> <%= patient.phone %></a>
                                    <% } %>
                                </div>
                            </div>
                        </td>
                        <td data-label="Hospital">
                            <div class="bb-issue-case">
                                <strong><%= item.hospitalName || '—' %></strong>
                                <span class="bb-issue-city"><i data-lucide="map-pin" style="width:12px;height:12px;"></i> <%= item.city || patient.city || '—' %></span>
                            </div>
                        </td>
                        <td data-label="Blood group">
                            <span class="overview-blood-badge bb-issue-blood"><%= item.bloodGroup %></span>
                        </td>
                        <td data-label="Units" class="text-center">
                            <span class="bb-issue-units"><%= item.units %><small>unit<%= Number(item.units) !== 1 ? 's' : '' %></small></span>
                        </td>
                        <td data-label="Stock" class="text-end">
                            <% if (prev != null && remaining != null) { %>
                            <div class="bb-issue-stock-delta">
                                <span class="bb-issue-stock-before"><%= prev %></span>
                                <i data-lucide="arrow-right" style="width:14px;height:14px;"></i>
                                <span class="bb-issue-stock-after"><%= remaining %> left</span>
                            </div>
                            <small class="text-muted">−<%= item.units %> deducted</small>
                            <% } else { %>
                            <span class="text-muted">—</span>
                            <% } %>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>

        <div id="bbIssueEmptyFilter" class="bb-issue-empty-filter d-none">
            <i data-lucide="filter-x" style="width:28px;height:28px;"></i>
            <p class="mb-2 fw-semibold">No records match your search</p>
            <button type="button" class="btn btn-sm btn-outline-danger" id="bbIssueClearSearch">Clear search</button>
        </div>
        <% } else { %>
        <div class="bb-issue-empty">
            <div class="bb-issue-empty-icon">
                <i data-lucide="history" style="width:32px;height:32px;"></i>
            </div>
            <h6>No blood issues recorded yet</h6>
            <p class="text-muted small mb-0">When a patient marks blood as received and selects your blood bank, the issue appears here and your inventory is updated automatically.</p>
        </div>
        <% } %>
    </div>
</div>

<div class="cp-hero mb-4">
    <div class="cp-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1519494027932-80aedc1da952?w=1400&h=420&fit=crop&q=85');"></div>
    <div class="cp-hero-overlay"></div>
    <div class="cp-hero-content">
        <div class="row align-items-end g-3">
            <div class="col-lg-8">
                <span class="cp-hero-badge"><i data-lucide="hospital" style="width:14px;height:14px;"></i> Hospital identity</span>
                <h3 class="cp-hero-title">Hospital profile</h3>
                <p class="cp-hero-sub mb-0">Manage your account contact details and hospital registration information shown to patients and admins.</p>
            </div>
            <div class="col-lg-4">
                <div class="cp-hero-meta">
                    <div><small>Hospital</small><strong class="text-truncate d-block"><%= bloodbank ? bloodbank.hospitalName : '—' %></strong></div>
                    <div><small>City</small><strong><%= user.city %></strong></div>
                    <div><small>Status</small><strong class="text-capitalize"><%= bloodbank ? bloodbank.status : 'setup' %></strong></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-6">
        <div class="overview-panel">
            <div class="overview-panel-head">
                <div class="d-flex align-items-center gap-3">
                    <%- include('../shared/user-avatar', { user, avatarSize: 'md' }) %>
                    <div>
                        <h5 class="mb-0">Account contact</h5>
                        <p class="text-muted small mb-0">Your personal login profile used for notifications and calls.</p>
                    </div>
                </div>
            </div>
            <div class="overview-panel-body">
                <form action="/auth/profile" method="POST" enctype="multipart/form-data" class="cp-form">
                    <%- include('../shared/profile-photo-field', { user, photoFieldPrefix: 'bb' }) %>
                    <div class="cp-field">
                        <label for="bbProfileName">Full name</label>
                        <div class="cp-input-wrap">
                            <i data-lucide="user" style="width:16px;height:16px;"></i>
                            <input type="text" name="name" id="bbProfileName" class="form-control" value="<%= user.name %>" required>
                        </div>
                    </div>
                    <div class="cp-field">
                        <label for="bbProfileCity">City</label>
                        <div class="cp-input-wrap">
                            <i data-lucide="map-pin" style="width:16px;height:16px;"></i>
                            <input type="text" name="city" id="bbProfileCity" class="form-control" value="<%= user.city %>" required>
                        </div>
                    </div>
                    <div class="cp-field">
                        <label for="bbProfilePhone">Phone</label>
                        <div class="cp-input-wrap">
                            <i data-lucide="phone" style="width:16px;height:16px;"></i>
                            <input type="tel" name="phone" id="bbProfilePhone" class="form-control" value="<%= user.phone %>" required pattern="[6-9][0-9]{9}">
                        </div>
                    </div>
                    <div class="cp-actions">
                        <button type="submit" class="btn btn-danger btn-sm">
                            <i data-lucide="save" style="width:14px;height:14px;"></i> Update account
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-6">
        <div class="overview-panel">
            <div class="overview-panel-head">
                <div class="d-flex align-items-center gap-3">
                    <div class="cp-form-icon">
                        <img src="https://images.unsplash.com/photo-1582719471137-c3967fb5767b?w=120&h=120&fit=crop&q=80" alt="" loading="lazy">
                    </div>
                    <div>
                        <h5 class="mb-0">Hospital details</h5>
                        <p class="text-muted small mb-0">Official blood bank / hospital name shown on the platform.</p>
                    </div>
                </div>
            </div>
            <div class="overview-panel-body">
                <% if (!bloodbank) { %>
                <div class="alert alert-warning mb-0">
                    No hospital profile yet. <a href="/bloodbank/setup">Complete setup</a> to register your blood bank.
                </div>
                <% } else { %>
                <form action="/bloodbank/profile" method="POST" class="cp-form" data-geo-form>
                    <div class="cp-field">
                        <label for="bbHospitalName">Hospital / blood bank name</label>
                        <div class="cp-input-wrap">
                            <i data-lucide="building-2" style="width:16px;height:16px;"></i>
                            <input type="text" name="hospitalName" id="bbHospitalName" class="form-control" value="<%= bloodbank.hospitalName %>" required>
                        </div>
                    </div>
                    <p class="small text-muted">Location is captured automatically from your device when you save (used for nearby patient matching).</p>
                    <input type="hidden" name="latitude" data-geo-lat>
                    <input type="hidden" name="longitude" data-geo-lng>
                    <div class="cp-actions">
                        <button type="submit" class="btn btn-danger btn-sm">
                            <i data-lucide="save" style="width:14px;height:14px;"></i> Update hospital
                        </button>
                    </div>
                </form>
                <% } %>
            </div>
        </div>
    </div>
</div>

<div class="overview-panel">
    <div class="overview-panel-head"><h5>Profile summary</h5></div>
    <div class="overview-panel-body">
        <div class="row g-3">
            <div class="col-md-3"><div class="bb-summary-tile"><small>Account email</small><strong><%= user.email %></strong></div></div>
            <div class="col-md-3"><div class="bb-summary-tile"><small>Contact person</small><strong><%= user.name %></strong></div></div>
            <div class="col-md-3"><div class="bb-summary-tile"><small>Phone</small><strong><a href="tel:<%= user.phone %>"><%= user.phone %></a></strong></div></div>
            <div class="col-md-3"><div class="bb-summary-tile"><small>Operating city</small><strong><%= user.city %></strong></div></div>
        </div>
    </div>
</div>

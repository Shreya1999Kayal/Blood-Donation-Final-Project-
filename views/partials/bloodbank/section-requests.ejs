<%
function statusLabel(s) {
    if (s === 'fulfilled') return 'received';
    return s;
}
const requests = bloodRequests || [];
const activeList = requests.filter(function(r) { return ['active', 'contacted'].includes(r.status); });
const criticalList = requests.filter(function(r) {
    return String(r.urgencyLevel).toLowerCase() === 'critical' && !['received', 'fulfilled', 'cancelled'].includes(r.status);
});
const contactedCount = requests.filter(function(r) { return r.status === 'contacted'; }).length;
const totalUnits = activeList.reduce(function(sum, r) { return sum + Number(r.requiredUnits || 0); }, 0);
const canRespond = bloodbank && bloodbank.status === 'approved';

const reqStats = [
    { label: 'Total requests', value: requests.length, icon: 'clipboard-list', tone: 'slate', img: 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=400&h=260&fit=crop&q=80' },
    { label: 'Live emergencies', value: activeList.length, icon: 'siren', tone: 'red', img: 'https://images.unsplash.com/photo-1538108149393-fbbd81895907?w=400&h=260&fit=crop&q=80' },
    { label: 'Critical cases', value: criticalList.length, icon: 'alert-triangle', tone: 'amber', img: 'https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=400&h=260&fit=crop&q=80' },
    { label: 'Units needed (live)', value: totalUnits, icon: 'droplets', tone: 'rose', img: 'https://images.unsplash.com/photo-1628348068343-c6a848d2b126?w=400&h=260&fit=crop&q=80' },
];
%>

<div class="req-hero mb-4">
    <div class="req-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1584982751661-6085a089094a?w=1400&h=420&fit=crop&q=85');"></div>
    <div class="req-hero-overlay"></div>
    <div class="req-hero-content">
        <div class="row align-items-end g-3">
            <div class="col-lg-8">
                <span class="req-hero-badge"><span class="pulse-dot"></span> Emergency response desk</span>
                <h3 class="req-hero-title">Emergency blood requests</h3>
                <p class="req-hero-sub mb-0">Review live patient cases, contact families, and coordinate blood supply from your hospital inventory.</p>
            </div>
            <div class="col-lg-4">
                <div class="req-hero-meta">
                    <div><small>Active now</small><strong><%= activeList.length %></strong></div>
                    <div><small>Critical</small><strong class="text-warning"><%= criticalList.length %></strong></div>
                    <div><small>In progress</small><strong><%= contactedCount %></strong></div>
                </div>
            </div>
        </div>
    </div>
</div>

<% if (!canRespond) { %>
<div class="bb-gate-banner mb-4">
    <i data-lucide="shield-alert" style="width:22px;height:22px;"></i>
    <div>
        <strong>Contact actions locked</strong>
        <p class="mb-0 small">Your blood bank must be approved by admin before you can contact patients. You can still monitor requests below.</p>
    </div>
</div>
<% } %>

<% if (criticalList.length > 0) { %>
<div class="req-critical-strip mb-4">
    <div class="req-critical-strip-icon">
        <img src="https://images.unsplash.com/photo-1516549655169-df83a0774514?w=100&h=100&fit=crop&q=80" alt="" loading="lazy">
    </div>
    <div class="flex-grow-1">
        <h6 class="mb-1"><i data-lucide="alert-circle" style="width:16px;height:16px;" class="me-1"></i> <%= criticalList.length %> critical case<%= criticalList.length !== 1 ? 's' : '' %> need immediate response</h6>
        <p class="mb-0 small text-muted">Prioritize patients with critical urgency and matching stock in your inventory.</p>
    </div>
    <button type="button" class="btn btn-danger btn-sm" id="reqFilterCritical">Show critical only</button>
</div>
<% } %>

<div class="row g-3 mb-4">
    <% reqStats.forEach(function(stat) { %>
    <div class="col-sm-6 col-xl-3">
        <div class="overview-kpi overview-kpi-<%= stat.tone %>">
            <div class="overview-kpi-visual">
                <img src="<%= stat.img %>" alt="" loading="lazy">
                <div class="overview-kpi-visual-shade"></div>
            </div>
            <div class="overview-kpi-body">
                <div class="overview-kpi-icon"><i data-lucide="<%= stat.icon %>" style="width:20px;height:20px;"></i></div>
                <div class="overview-kpi-label"><%= stat.label %></div>
                <div class="overview-kpi-value"><%= stat.value %></div>
            </div>
        </div>
    </div>
    <% }); %>
</div>

<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="overview-panel">
            <div class="overview-panel-head flex-wrap">
                <div>
                    <h5>Request board</h5>
                    <p class="text-muted small mb-0"><span id="reqVisibleCount"><%= requests.length %></span> of <%= requests.length %> request(s) shown</p>
                </div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <div class="btn-group btn-group-sm req-view-toggle" role="group">
                        <button type="button" class="btn btn-danger active" data-req-view="cards" title="Card view"><i data-lucide="layout-grid" style="width:14px;height:14px;"></i></button>
                        <button type="button" class="btn btn-outline-secondary" data-req-view="table" title="Table view"><i data-lucide="table" style="width:14px;height:14px;"></i></button>
                    </div>
                </div>
            </div>

            <div class="req-toolbar">
                <div class="req-search-wrap">
                    <i data-lucide="search" style="width:16px;height:16px;"></i>
                    <input type="search" class="form-control form-control-sm" id="reqSearch" placeholder="Search patient, hospital, city, blood type…" autocomplete="off">
                </div>
                <div class="req-filter-group">
                    <span class="req-filter-label">Status</span>
                    <div class="req-pills" id="reqStatusFilters">
                        <button type="button" class="req-pill active" data-req-status="all">All</button>
                        <button type="button" class="req-pill" data-req-status="live">Live</button>
                        <button type="button" class="req-pill" data-req-status="active">Active</button>
                        <button type="button" class="req-pill" data-req-status="contacted">Contacted</button>
                        <button type="button" class="req-pill" data-req-status="closed">Closed</button>
                    </div>
                </div>
                <div class="req-filter-group">
                    <span class="req-filter-label">Urgency</span>
                    <div class="req-pills" id="reqUrgencyFilters">
                        <button type="button" class="req-pill active" data-req-urgency="all">All</button>
                        <button type="button" class="req-pill" data-req-urgency="critical">Critical</button>
                        <button type="button" class="req-pill" data-req-urgency="high">High</button>
                        <button type="button" class="req-pill" data-req-urgency="normal">Normal</button>
                    </div>
                </div>
            </div>

            <div class="overview-panel-body pt-0">
                <div id="reqCardsView">
                    <%- include('../admin/blood-requests-admin', { bloodRequests: requests, user, bloodbank, donorProfile: null }) %>
                </div>
                <div id="reqTableView" class="d-none">
                    <%- include('../shared/advanced-blood-requests-table', { bloodRequests: requests, user, donorProfile: null, bloodbank, twTheme: 'bloodbank' }) %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Hero -->
<div class="cp-hero mb-4">
    <div class="cp-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1563986768609-322da13575f3?w=1400&h=420&fit=crop&q=85');"></div>
    <div class="cp-hero-overlay"></div>
    <div class="cp-hero-content">
        <div class="row align-items-end g-3">
            <div class="col-lg-8">
                <span class="cp-hero-badge"><i data-lucide="shield-check" style="width:14px;height:14px;"></i> Account security</span>
                <h3 class="cp-hero-title">Change password</h3>
                <p class="cp-hero-sub mb-0">Keep your hospital account secure with a strong, unique password. Changes take effect immediately and refresh your session.</p>
            </div>
            <div class="col-lg-4">
                <div class="cp-hero-meta">
                    <div><small>Signed in as</small><strong class="text-truncate d-block" style="font-size:0.85rem;"><%= user.name %></strong></div>
                    <div><small>Email</small><strong class="text-truncate d-block" style="font-size:0.75rem;"><%= user.email %></strong></div>
                    <div><small>Role</small><strong>Blood Bank</strong></div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../shared/password-flash-alerts', { flash }) %>

<div class="row g-4 mb-4">    <div class="col-xl-7">
        <div class="overview-panel cp-form-panel">
            <div class="overview-panel-head">
                <div class="d-flex align-items-center gap-3">
                    <div class="cp-form-icon">
                        <img src="https://images.unsplash.com/photo-1614064641938-3bbee52942c7?w=120&h=120&fit=crop&q=80" alt="" loading="lazy">
                    </div>
                    <div>
                        <h5 class="mb-0">Update credentials</h5>
                        <p class="text-muted small mb-0">Enter your current password, then choose a new one.</p>
                    </div>
                </div>
            </div>
            <div class="overview-panel-body">
                <form action="/auth/change-password" method="POST" id="cpForm" class="cp-form" novalidate>
                    <div class="cp-field">
                        <label for="cpCurrent">Current password</label>
                        <div class="cp-input-wrap">
                            <i data-lucide="lock" style="width:16px;height:16px;"></i>
                            <input type="password" name="currentPassword" id="cpCurrent" class="form-control" required autocomplete="current-password" placeholder="Enter current password">
                            <button type="button" class="cp-toggle-pw" data-target="cpCurrent" aria-label="Show password"><i data-lucide="eye" style="width:16px;height:16px;"></i></button>
                        </div>
                    </div>
                    <div class="cp-field">
                        <label for="cpNew">New password</label>
                        <div class="cp-input-wrap">
                            <i data-lucide="key-round" style="width:16px;height:16px;"></i>
                            <input type="password" name="newPassword" id="cpNew" class="form-control" required autocomplete="new-password" placeholder="Enter new password">
                            <button type="button" class="cp-toggle-pw" data-target="cpNew" aria-label="Show password"><i data-lucide="eye" style="width:16px;height:16px;"></i></button>
                        </div>
                    </div>
                    <div class="cp-field">
                        <label for="cpConfirm">Confirm new password</label>
                        <div class="cp-input-wrap">
                            <i data-lucide="shield" style="width:16px;height:16px;"></i>
                            <input type="password" name="confirmPassword" id="cpConfirm" class="form-control" required autocomplete="new-password" placeholder="Re-enter new password">
                            <button type="button" class="cp-toggle-pw" data-target="cpConfirm" aria-label="Show password"><i data-lucide="eye" style="width:16px;height:16px;"></i></button>
                        </div>
                        <small class="cp-match-hint d-none text-danger" id="cpMatchHint"><i data-lucide="x-circle" style="width:12px;height:12px;"></i> Passwords do not match</small>
                    </div>
                    <div class="cp-actions">
                        <button type="submit" class="btn btn-danger" id="cpSubmit">
                            <i data-lucide="save" style="width:16px;height:16px;"></i> Change password
                        </button>
                        <button type="reset" class="btn btn-outline-secondary">Clear form</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-5">
        <div class="overview-panel mb-4">
            <div class="overview-panel-head"><h5>Security checklist</h5></div>
            <div class="overview-panel-body pt-2">
                <div class="cp-tip">
                    <img src="https://images.unsplash.com/photo-1563986768494-4ccb4962f667?w=80&h=80&fit=crop&q=80" alt="" loading="lazy">
                    <div>
                        <strong>Use a unique password</strong>
                        <p class="small text-muted mb-0">Do not reuse passwords from other sites or services.</p>
                    </div>
                </div>
                <div class="cp-tip">
                    <img src="https://images.unsplash.com/photo-1555949963-aa79dcee981c?w=80&h=80&fit=crop&q=80" alt="" loading="lazy">
                    <div>
                        <strong>Mix characters</strong>
                        <p class="small text-muted mb-0">Combine letters, numbers, and symbols for stronger protection.</p>
                    </div>
                </div>
                <div class="cp-tip mb-0">
                    <img src="https://images.unsplash.com/photo-1633265486064-086b219458ec?w=80&h=80&fit=crop&q=80" alt="" loading="lazy">
                    <div>
                        <strong>Session refresh</strong>
                        <p class="small text-muted mb-0">After changing your password, a new secure session is issued automatically.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="overview-panel overview-panel-accent">
            <div class="overview-panel-head border-0 pb-0"><h5 class="text-white mb-0">Need help?</h5></div>
            <div class="overview-panel-body">
                <p class="small mb-3" style="color:rgba(255,255,255,0.75);">If you forgot your password, sign out and use the forgot-password flow from the login page.</p>
                <a href="/auth/logout" class="btn btn-outline-light btn-sm">
                    <i data-lucide="log-out" style="width:14px;height:14px;"></i> Sign out securely
                </a>
            </div>
        </div>
    </div>
</div>

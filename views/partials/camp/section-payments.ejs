<%
const payments = campPayments || [];
const summary = campPaymentSummary || { totalSpent: 0, donorUnlocks: 0, bankUnlocks: 0, transactionCount: 0 };
const fees = campUnlockFees || { donorDirectory: 500, donorContact: 5, bloodbank: 1000 };

function formatInr(n) {
    return '₹' + Number(n || 0).toLocaleString('en-IN');
}

function formatDate(d) {
    if (!d) return '—';
    return new Date(d).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' });
}

function statusClass(status) {
    if (status === 'paid') return 'cp-pay-status cp-pay-status--paid';
    if (status === 'failed') return 'cp-pay-status cp-pay-status--failed';
    if (status === 'refunded') return 'cp-pay-status cp-pay-status--refunded';
    return 'cp-pay-status cp-pay-status--pending';
}
%>
<div class="cp-hero mb-4">
    <div class="cp-hero-bg" style="background-image:url('https://images.unsplash.com/photo-1563986768494-4ccb4962f667?w=1400&h=420&fit=crop&q=85');"></div>
    <div class="cp-hero-overlay"></div>
    <div class="cp-hero-content">
        <span class="cp-hero-badge"><i data-lucide="receipt" style="width:14px;height:14px;"></i> Billing & unlocks</span>
        <h3 class="cp-hero-title">Payment history</h3>
        <p class="cp-hero-sub mb-0">Track Razorpay payments for donor and blood bank contact unlocks. Unlocks remain active after successful payment.</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="cp-pay-stat">
            <small>Total spent</small>
            <strong><%= formatInr(summary.totalSpent) %></strong>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="cp-pay-stat">
            <small>Donor directory</small>
            <strong><%= summary.directoryUnlocked ? 'Unlocked' : 'Locked' %></strong>
            <span class="cp-pay-stat-sub"><%= summary.directoryUnlocked ? 'All donor contacts' : formatInr(fees.donorDirectory) + ' one-time' %></span>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="cp-pay-stat">
            <small>Donor contact unlocks</small>
            <strong><%= summary.donorUnlocks %></strong>
            <span class="cp-pay-stat-sub">@ <%= formatInr(fees.donorContact) %> each</span>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="cp-pay-stat">
            <small>Blood bank unlocks</small>
            <strong><%= summary.bankUnlocks %></strong>
            <span class="cp-pay-stat-sub">@ <%= formatInr(fees.bloodbank) %> each</span>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="cp-pay-stat">
            <small>Successful payments</small>
            <strong><%= summary.transactionCount %></strong>
        </div>
    </div>
</div>

<div class="overview-panel cp-pay-panel">
    <div class="cp-pay-toolbar">
        <span class="cp-pay-toolbar-title">Transaction ledger</span>
        <span class="cp-pay-toolbar-meta"><%= payments.length %> record<%= payments.length === 1 ? '' : 's' %></span>
    </div>
    <div class="overview-panel-body pt-0">
        <% if (payments.length) { %>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 cp-pay-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Purpose</th>
                        <th>Unlocked contact</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Reference</th>
                    </tr>
                </thead>
                <tbody>
                    <% payments.forEach(function(p) { %>
                    <tr>
                        <td class="text-nowrap"><%= formatDate(p.paidAt || p.createdAt) %></td>
                        <td>
                            <span class="cp-pay-purpose">
                                <i data-lucide="<%= p.targetType === 'donor' ? 'droplet' : (p.targetType === 'directory' ? 'users' : 'building-2') %>" style="width:14px;height:14px;"></i>
                                <%= p.purposeLabel %>
                            </span>
                        </td>
                        <td><strong><%= p.targetLabel %></strong></td>
                        <td class="fw-bold text-nowrap"><%= formatInr(p.amount) %></td>
                        <td><span class="<%= statusClass(p.status) %> text-capitalize"><%= p.status %></span></td>
                        <td>
                            <% if (p.paymentId) { %>
                                <code class="cp-pay-ref" title="<%= p.paymentId %>"><%= p.paymentId.slice(0, 14) %>…</code>
                            <% } else if (p.orderId) { %>
                                <code class="cp-pay-ref" title="<%= p.orderId %>"><%= p.orderId.slice(0, 14) %>…</code>
                            <% } else { %>
                                <span class="text-muted">—</span>
                            <% } %>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <% } else { %>
        <div class="cp-pay-empty">
            <i data-lucide="wallet" style="width:40px;height:40px;color:#a78bfa;"></i>
            <h5>No payments yet</h5>
            <p class="text-muted mb-3">Unlock donor or blood bank contacts from the directory — payments appear here instantly after Razorpay confirmation.</p>
            <a href="#" class="btn btn-sm btn-primary" style="background:#7c3aed;border-color:#6d28d9" data-cp-section="donors" data-cp-label="Donor Directory">Browse donors</a>
        </div>
        <% } %>
    </div>
    <div class="cp-pay-footer">
        <i data-lucide="shield-check" style="width:14px;height:14px;"></i>
        Payments are processed securely via Razorpay. Failed attempts may appear with status <strong>failed</strong> or <strong>created</strong>.
    </div>
</div>

<% if (typeof razorpayKeyId !== 'undefined' && razorpayKeyId && razorpayKeyId.indexOf('rzp_test_') === 0) { %>
<div class="alert alert-info mt-3 mb-0">
    <strong>Test payment tip</strong>
    <p class="mb-0 small">Use <strong>UPI</strong> → enter <code>success@razorpay</code> → pay (works without OTP). Card payments fail if you skip the OTP step — that is normal in Razorpay test mode.</p>
</div>
<% } %>

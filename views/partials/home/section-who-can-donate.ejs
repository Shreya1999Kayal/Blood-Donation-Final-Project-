<section class="home-section" id="who-can-donate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-5 gap-10 items-start">
            <div class="lg:col-span-2">
                <span class="home-badge">Eligibility</span>
                <h2 class="home-section-title mt-4">Who can donate blood?</h2>
                <p class="home-section-lead">Healthy adults meeting national guidelines can save up to three lives with a single donation. Always consult a medical professional before donating.</p>
                <a href="/auth/register?role=donor" class="inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-full bg-brand-600 hover:bg-brand-700 text-white font-bold text-sm no-underline transition-colors">
                    Check eligibility &amp; register
                    <i data-lucide="arrow-right" style="width:18px;height:18px;"></i>
                </a>
            </div>
            <div class="lg:col-span-3 grid sm:grid-cols-2 gap-4">
                <% const eligible = [
                    'Age between 18 and 65 years (first-time donors: 18–60)',
                    'Weight at least 45 kg with normal hemoglobin levels',
                    'Good general health — no fever, infection, or chronic illness',
                    'At least 90 days since last whole blood donation',
                    'No high-risk behaviour as per national screening guidelines',
                    'Not pregnant or breastfeeding (for women donors)',
                ]; %>
                <% eligible.forEach(function(item) { %>
                    <div class="home-eligibility-item">
                        <span class="check"><i data-lucide="check" style="width:16px;height:16px;"></i></span>
                        <span class="text-sm font-medium text-slate-700"><%= item %></span>
                    </div>
                <% }); %>

                <div class="home-eligibility-item cross sm:col-span-2">
                    <span class="check"><i data-lucide="x" style="width:16px;height:16px;"></i></span>
                    <span class="text-sm font-medium text-slate-700">Temporary deferral applies if you have recent surgery, tattoos (within 6 months), malaria treatment, or are on certain medications — blood bank staff will advise at screening.</span>
                </div>
            </div>
        </div>
    </div>
</section>

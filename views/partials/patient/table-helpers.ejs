<%
function ptInitials(name) {
    if (!name) return '?';
    return name.split(' ').map(function (p) { return p[0]; }).slice(0, 2).join('').toUpperCase();
}
function ptStatusLabel(s) {
    if (s === 'fulfilled') return 'received';
    return s;
}
function ptStatusTw(s) {
    const label = ptStatusLabel(s);
    const map = {
        active: 'bg-amber-50 text-amber-800 ring-amber-600/20',
        contacted: 'bg-sky-50 text-sky-800 ring-sky-600/20',
        received: 'bg-emerald-50 text-emerald-800 ring-emerald-600/20',
        cancelled: 'bg-slate-100 text-slate-600 ring-slate-500/20',
    };
    return map[label] || map.cancelled;
}
function ptBadgeBase() {
    return 'inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold ring-1 ring-inset';
}
function ptBloodTw() {
    return ptBadgeBase() + ' bg-rose-50 text-rose-700 ring-rose-600/20';
}
function ptThClass() {
    return 'px-4 py-3.5 text-left text-[11px] font-semibold uppercase tracking-wider text-slate-500 whitespace-nowrap';
}
function ptTdClass() {
    return 'px-4 py-3.5 align-middle text-slate-700';
}
function ptRowClass() {
    return 'transition-colors hover:bg-slate-50/90 group';
}
function ptChatBtnClass() {
    return 'chat-btn inline-flex items-center gap-1.5 rounded-lg border border-rose-200 bg-white px-3 py-1.5 text-xs font-semibold text-rose-700 shadow-sm transition hover:border-rose-300 hover:bg-rose-50 hover:text-rose-800 focus:outline-none focus:ring-2 focus:ring-rose-500/30';
}
function ptPhoneLinkClass() {
    return 'font-medium text-slate-800 hover:text-rose-600 transition';
}
function ptEligibilityTw(kind) {
    const map = {
        success: 'bg-emerald-50 text-emerald-800 ring-emerald-600/20',
        danger: 'bg-rose-50 text-rose-800 ring-rose-600/20',
        warning: 'bg-amber-50 text-amber-800 ring-amber-600/20',
        secondary: 'bg-slate-100 text-slate-600 ring-slate-500/20',
    };
    return ptBadgeBase() + ' ' + (map[kind] || map.secondary);
}
function donorCooldownDays(donor) {
    if (!donor || !donor.lastDonationDate) return 999;
    return Math.floor((Date.now() - new Date(donor.lastDonationDate).getTime()) / (1000 * 60 * 60 * 24));
}
function donorCooldownRemaining(donor) {
    return Math.max(0, 90 - donorCooldownDays(donor));
}
function donorEligibilityLabel(donor) {
    if (!donor || donor.status !== 'approved') return 'Pending approval';
    const remaining = donorCooldownRemaining(donor);
    if (remaining > 0) return 'Not eligible (' + remaining + 'd left)';
    if (!donor.isAvailable) return 'Unavailable';
    return 'Eligible';
}
function donorEligibilityBadge(donor) {
    if (!donor || donor.status !== 'approved') return 'warning';
    if (donorCooldownRemaining(donor) > 0) return 'danger';
    if (!donor.isAvailable) return 'secondary';
    return 'success';
}
%>

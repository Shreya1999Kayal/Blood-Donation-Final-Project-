<%
function ptInitials(name) {
    if (!name) return '?';
    return name.split(' ').map(function (p) { return p[0]; }).slice(0, 2).join('').toUpperCase();
}
function donorCooldownDays(donor) {
    if (!donor || !donor.lastDonationDate) return 999;
    return Math.floor((Date.now() - new Date(donor.lastDonationDate).getTime()) / (1000 * 60 * 60 * 24));
}
function donorCooldownRemaining(donor) {
    return Math.max(0, 90 - donorCooldownDays(donor));
}
function donorEligibilityLabel(donor) {
    if (!donor || donor.status !== 'approved') return 'Pending approval';
    const remaining = donorCooldownRemaining(donor);
    if (remaining > 0) return 'Not eligible (' + remaining + 'd left)';
    if (!donor.isAvailable) return 'Unavailable';
    return 'Eligible';
}
function donorEligibilityBadge(donor) {
    if (!donor || donor.status !== 'approved') return 'warning';
    if (donorCooldownRemaining(donor) > 0) return 'danger';
    if (!donor.isAvailable) return 'secondary';
    return 'success';
}
const donors = approvedDonors || [];
const latestActiveRequest = (bloodRequests || []).find(function(r) {
    return ['active', 'contacted'].includes(r.status);
});
const defaultBloodGroup = latestActiveRequest ? latestActiveRequest.bloodGroup : '';
%>

<div class="cp-hero mb-4 pt-hero">
    <div class="cp-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1615461066159-fa5966998606?w=1400&h=420&fit=crop&q=85');"></div>
    <div class="cp-hero-overlay"></div>
    <div class="cp-hero-content">
        <div class="row align-items-end g-3">
            <div class="col-lg-8">
                <span class="cp-hero-badge"><i data-lucide="users" style="width:14px;height:14px;"></i> Verified donors</span>
                <h3 class="cp-hero-title">Find blood donors</h3>
                <p class="cp-hero-sub mb-0">Use <strong>Search near me</strong> to find the closest verified donors by GPS location.</p>
            </div>
            <div class="col-lg-4">
                <div class="cp-hero-meta">
                    <div><small>Listed</small><strong><%= donors.length %></strong></div>
                    <div><small>Your city</small><strong><%= user.city %></strong></div>
                    <div><small>Status</small><strong class="text-success">Live directory</strong></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="overview-panel">
            <div class="overview-panel-head d-flex flex-wrap align-items-center justify-content-between gap-2">
                <h5 class="mb-0">Search donors</h5>
                <button type="button" class="btn btn-success btn-sm d-inline-flex align-items-center gap-1" data-near-me-search="donorSearchForm">
                    <i data-lucide="map-pin" style="width:14px;height:14px;"></i> Search near me
                </button>
            </div>
            <div class="overview-panel-body">
                <p class="small mb-2" data-geo-status id="donorGeoStatus"></p>
                <form class="row g-2 pt-search-card" id="donorSearchForm" data-search-geo-form>
                    <div class="col-md-3">
                        <select name="bloodGroup" class="form-select form-select-sm">
                            <option value="">Blood group</option>
                            <% ['A+','A-','B+','B-','AB+','AB-','O+','O-'].forEach(function(bg) { %>
                                <option value="<%= bg %>" <%= defaultBloodGroup === bg ? 'selected' : '' %>><%= bg %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <input name="city" class="form-control form-control-sm" placeholder="City or area (optional)" value="">
                    </div>
                    <div class="col-md-3">
                        <select name="availability" class="form-select form-select-sm">
                            <option value="">Any availability</option>
                            <option value="available">Available</option>
                            <option value="unavailable">Unavailable</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <input name="radiusKm" type="number" class="form-control form-control-sm" data-radius-input data-near-me-only value="20" min="1" placeholder="Radius (km)">
                    </div>
                    <div class="col-12 d-flex flex-wrap align-items-center gap-2" data-radius-presets data-near-me-only>
                        <span class="small text-muted">Radius:</span>
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-radius-km="5">5 km</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm active" data-radius-km="20">20 km</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-radius-km="10">10 km</button>
                        <button type="submit" class="btn btn-danger btn-sm ms-auto">Search donors</button>
                    </div>
                </form>
                <div id="donorSearchResults" class="mb-3"></div>
                <p class="small text-muted mb-3" id="donorSearchHint">Search by <strong>blood group</strong> and/or <strong>city</strong> — no GPS needed. Use <strong>Search near me</strong> only for location-based results.</p>

                <div class="pt-donor-registry">
                    <div class="pt-donor-registry-head">
                        <span class="pt-donor-registry-title">
                            <i data-lucide="users"></i>
                            Approved donor directory
                        </span>
                        <span class="pt-donor-registry-count"><%= donors.length %> listed</span>
                    </div>
                    <div class="pt-donor-registry-scroll">
                        <table class="pt-donor-table">
                            <thead>
                                <tr>
                                    <th>Donor</th>
                                    <th>Blood group</th>
                                    <th>City</th>
                                    <th>Phone</th>
                                    <th>Eligibility</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (donors.length) { %>
                                    <% donors.forEach(function(d) {
                                        const name = d.userId ? d.userId.name : '—';
                                        const donorUser = d.userId || {};
                                        const eligKind = donorEligibilityBadge(d);
                                    %>
                                    <tr class="pt-donor-row">
                                        <td>
                                            <div class="pt-donor-cell">
                                                <% if (profileImageUrl(donorUser)) { %>
                                                <img src="<%= profileImageUrl(donorUser) %>" alt="" class="pt-donor-avatar pt-donor-avatar--photo" loading="lazy">
                                                <% } else { %>
                                                <span class="pt-donor-avatar pt-donor-avatar--initials"><%= ptInitials(name) %></span>
                                                <% } %>
                                                <div class="pt-donor-meta">
                                                    <span class="pt-donor-name" title="<%= name %>"><%= name %></span>
                                                    <% if (donorUser.email) { %>
                                                    <span class="pt-donor-email"><%= donorUser.email %></span>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="pt-donor-blood"><%= d.bloodGroup %></span></td>
                                        <td>
                                            <span class="pt-donor-city">
                                                <i data-lucide="map-pin"></i>
                                                <%= donorUser.city || '—' %>
                                            </span>
                                        </td>
                                        <td class="pt-donor-phone">
                                            <% if (donorUser.phone) { %>
                                            <a href="tel:<%= donorUser.phone %>"><%= donorUser.phone %></a>
                                            <% } else { %><span class="pt-donor-muted">—</span><% } %>
                                        </td>
                                        <td>
                                            <span class="pt-donor-elig pt-donor-elig--<%= eligKind %>"><%= donorEligibilityLabel(d) %></span>
                                        </td>
                                        <td class="text-end">
                                            <% if (donorUser._id) { %>
                                            <button type="button" class="btn btn-outline-danger btn-sm chat-btn pt-donor-chat-btn"
                                                data-user-id="<%= donorUser._id %>"
                                                data-user-name="<%= donorUser.name %>"
                                                data-user-role="donor">
                                                <i data-lucide="message-circle"></i> Chat
                                            </button>
                                            <% } else { %>
                                            <span class="pt-donor-muted">—</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="pt-donor-empty">
                                            <i data-lucide="users"></i>
                                            <p><strong>No approved donors yet</strong></p>
                                            <span>Check back later or widen your search radius.</span>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

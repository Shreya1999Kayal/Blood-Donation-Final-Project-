<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Verify Email — RaktaSetu</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .otp-input { font-size: 1.5rem; letter-spacing: 0.4rem; text-align: center; }
    </style>
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h3 class="text-center mb-2">Verify your email</h3>
                        <p class="text-muted small text-center mb-4">After phone verification, we will email you a 6-digit code to verify your address.</p>
                        <% if (phoneVerified) { %>
                            <div class="alert alert-success py-2">Phone verified. Now verify your email to finish registration.</div>
                        <% } %>

                        <% if (error) { %>
                            <div class="alert alert-danger py-2"><%= error %></div>
                        <% } %>
                        <% if (success) { %>
                            <div class="alert alert-success py-2"><%= success %></div>
                        <% } %>
                        <% if (sent && !success) { %>
                            <div class="alert alert-info py-2">Check your inbox for the verification code.</div>
                        <% } %>
                        <% if (verified) { %>
                            <div class="alert alert-success py-2">Email already verified. <a href="<%= typeof loginUrl !== 'undefined' ? loginUrl : '/auth/login' %>">Log in</a></div>
                        <% } %>

                        <form action="/auth/verify-otp" method="POST">
                            <div class="mb-3">
                                <label>Email</label>
                                <input type="email" name="email" class="form-control" value="<%= email %>" required>
                            </div>
                            <div class="mb-3">
                                <label>Verification code (OTP)</label>
                                <input type="text" name="otp" class="form-control otp-input"
                                    maxlength="6" pattern="[0-9]{6}" inputmode="numeric" autocomplete="one-time-code"
                                    placeholder="000000" required>
                                <div class="form-text">Code expires in 10 minutes.</div>
                            </div>
                            <button type="submit" class="btn btn-danger w-100">Verify email</button>
                        </form>

                        <form action="/auth/resend-otp" method="POST" class="mt-3">
                            <input type="hidden" name="email" value="<%= email %>">
                            <button type="submit" class="btn btn-outline-secondary w-100 btn-sm">Resend code</button>
                        </form>

                        <p class="text-center mt-3 mb-0">
                            <a href="<%= typeof loginUrl !== 'undefined' ? loginUrl : '/auth/login' %>">Back to login</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

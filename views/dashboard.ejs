<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard — RaktaSetu</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <% if (['user', 'donor', 'bloodbank'].includes(user.role)) { %>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <% } %>
    <% if (user.role === 'admin') { %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <% } %>
    <% if (['donor', 'bloodbank', 'admin', 'user'].includes(user.role)) { %>
    <script src="/socket.io/socket.io.js"></script>
    <% } %>
</head>
<body class="bg-light">
    <%
    function donorCooldownDays(donor) {
        if (!donor || !donor.lastDonationDate) return 999;
        return Math.floor((Date.now() - new Date(donor.lastDonationDate).getTime()) / (1000 * 60 * 60 * 24));
    }
    function donorCooldownRemaining(donor) {
        return Math.max(0, 90 - donorCooldownDays(donor));
    }
    function donorEligibilityLabel(donor) {
        if (!donor || donor.status !== 'approved') return 'Pending approval';
        const remaining = donorCooldownRemaining(donor);
        if (remaining > 0) return 'Not eligible (' + remaining + ' days left)';
        if (!donor.isAvailable) return 'Unavailable';
        return 'Eligible';
    }
    function donorEligibilityBadge(donor) {
        if (!donor || donor.status !== 'approved') return 'warning';
        if (donorCooldownRemaining(donor) > 0) return 'danger';
        if (!donor.isAvailable) return 'secondary';
        return 'success';
    }
    %>
    <nav class="navbar navbar-expand-lg navbar-dark bg-danger">
        <div class="container">
            <a class="navbar-brand" href="/">🩸 RaktaSetu</a>
            <div class="collapse navbar-collapse justify-content-end">
                <span class="navbar-text text-white me-3">Welcome, <%= user.name %> (<%= user.role %>)</span>
                <% if (['user', 'donor', 'bloodbank'].includes(user.role)) { %>
                    <a class="btn btn-light btn-sm me-2" href="/messages">💬 Messages</a>
                <% } %>
                <a class="btn btn-outline-light btn-sm me-2" href="/auth/change-password">Change password</a>
                <a class="btn btn-outline-light btn-sm" href="/auth/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4 mb-5">
        <% if (typeof flash !== 'undefined' && flash) { %>
            <% if (flash.msg === 'request_created') { %><div class="alert alert-success">Emergency request posted.</div><% } %>
            <% if (flash.msg === 'contact_recorded') { %><div class="alert alert-success">Contact recorded on request.</div><% } %>
            <% if (flash.msg === 'marked_received') { %><div class="alert alert-success">Request marked as received.</div><% } %>
            <% if (flash.msg === 'donor_docs_submitted') { %><div class="alert alert-info">Documents submitted. Waiting for admin approval.</div><% } %>
            <% if (flash.msg === 'bloodbank_submitted') { %><div class="alert alert-info">Blood bank submitted with certificate. Waiting for admin approval.</div><% } %>
            <% if (flash.msg === 'bloodbank_certificate_updated') { %><div class="alert alert-info">Registration certificate updated.</div><% } %>
            <% if (flash.msg === 'bloodbank_certificate_reverify') { %><div class="alert alert-warning">Certificate updated. Your blood bank must be re-verified by admin.</div><% } %>
            <% if (flash.msg === 'donor_approved') { %><div class="alert alert-success">Donor approved.</div><% } %>
            <% if (flash.msg === 'donor_rejected') { %><div class="alert alert-warning">Donor rejected.</div><% } %>
            <% if (flash.msg === 'bloodbank_approved') { %><div class="alert alert-success">Blood bank approved.</div><% } %>
            <% if (flash.msg === 'bloodbank_rejected') { %><div class="alert alert-warning">Blood bank rejected.</div><% } %>
            <% if (flash.msg === 'availability_updated') { %><div class="alert alert-success">Availability updated.</div><% } %>
            <% if (flash.msg === 'profile_updated') { %><div class="alert alert-success">Profile updated.</div><% } %>
            <% if (flash.msg === 'bloodbank_profile_updated') { %><div class="alert alert-success">Blood bank profile updated.</div><% } %>
            <% if (flash.msg === 'subscription_activated') { %><div class="alert alert-success">Subscription activated successfully.</div><% } %>
            <% if (flash.msg === 'payment_success') { %><div class="alert alert-success">Payment recorded successfully.</div><% } %>
            <% if (flash.error === 'patient_docs_required') { %><div class="alert alert-danger">Upload blood test report and prescription to create a request.</div><% } %>
            <% if (flash.error === 'donor_not_approved') { %><div class="alert alert-warning">You must be approved by admin before contacting patients.</div><% } %>
            <% if (flash.error === 'bloodbank_not_approved') { %><div class="alert alert-warning">Your blood bank must be approved by admin before contacting patients.</div><% } %>
            <% if (flash.error === 'bloodbank_certificate_required') { %><div class="alert alert-danger">Please upload your registered blood bank certificate.</div><% } %>
            <% if (flash.error === 'bloodbank_certificate_missing') { %><div class="alert alert-warning">Cannot approve blood bank without a registration certificate.</div><% } %>
            <% if (flash.error === 'request_closed') { %><div class="alert alert-warning">This request is already closed.</div><% } %>
            <% if (flash.error === 'already_received') { %><div class="alert alert-info">Request already marked as received.</div><% } %>
            <% if (flash.error === 'donor_cooldown') { %><div class="alert alert-warning">Donor is not eligible yet. A donor can donate only once in 90 days.</div><% } %>
            <% if (flash.error === 'select_responder') { %><div class="alert alert-warning">Select the donor or blood bank that provided blood before marking received.</div><% } %>
            <% if (flash.error && !['patient_docs_required','donor_not_approved','bloodbank_not_approved','bloodbank_certificate_required','bloodbank_certificate_missing','request_closed','already_received','donor_cooldown','select_responder'].includes(flash.error)) { %><div class="alert alert-danger"><%= flash.error %></div><% } %>
        <% } %>

        <% const isRequestsOnly = user.role === 'donor' || user.role === 'bloodbank'; %>
        <div class="row">
            <div class="<%= isRequestsOnly ? 'col-12' : 'col-md-8' %>">

                <% if (['user', 'donor', 'bloodbank'].includes(user.role)) { %>
                <div class="card shadow-sm mb-4 border-danger">
                    <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-2">
                        <div>
                            <h5 class="mb-1">💬 Live chat</h5>
                            <p class="small text-muted mb-0">
                                <% if (user.role === 'user') { %>
                                    Message approved donors & blood banks from the lists below, or open your inbox.
                                <% } else { %>
                                    Message patients from <strong>Emergency blood requests</strong> → <strong>Chat patient</strong>.
                                <% } %>
                            </p>
                        </div>
                        <a href="/messages" class="btn btn-danger">Open Messages</a>
                    </div>
                </div>
                <% } %>

                <% if (true) { %>
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h5>Your profile</h5>
                        <form action="/auth/profile" method="POST" class="row g-2 mb-2">
                            <div class="col-md-4">
                                <label class="form-label small">Name</label>
                                <input name="name" class="form-control" value="<%= user.name %>" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">City</label>
                                <input name="city" class="form-control" value="<%= user.city %>" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Phone</label>
                                <input name="phone" class="form-control" value="<%= user.phone %>" required pattern="[6-9][0-9]{9}">
                            </div>
                            <div class="col-12">
                                <button class="btn btn-outline-danger btn-sm">Update profile</button>
                            </div>
                        </form>
                        <p class="mb-0"><strong>Name:</strong> <%= user.name %> · <strong>City:</strong> <%= user.city %> · <strong>Phone:</strong> <%= user.phone %></p>
                    </div>
                </div>
                <% } %>

                <% if (['user', 'donor', 'bloodbank'].includes(user.role)) { %>
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Subscription plans</h5>
                        <span class="badge bg-dark text-uppercase"><%= (user.subscription && user.subscription.plan) || 'free' %></span>
                    </div>
                    <div class="card-body">
                        <p class="small text-muted mb-3">
                            <% if (user.role === 'user') { %>
                                <strong>Why pay?</strong> Free users can post requests, but paid plans give <em>priority visibility</em> so donors and blood banks see your emergency faster.
                            <% } else if (user.role === 'donor') { %>
                                <strong>Why pay?</strong> Free donors can respond to requests after admin approval. Paid plans rank you <em>higher in patient search</em> and AI matching so you get contacted sooner.
                            <% } else { %>
                                <strong>Why pay?</strong> Free blood banks can manage inventory. Paid plans rank your hospital <em>higher when patients search nearby banks</em> with stock.
                            <% } %>
                        </p>
                        <div class="row g-3">
                            <% ['premium', 'pro', 'advanced'].forEach(function(planKey) { %>
                                <% const price = planPrices[planKey]; %>
                                <% const benefits = (planBenefits && planBenefits[planKey]) || []; %>
                                <% const isCurrent = user.subscription && user.subscription.plan === planKey && hasActiveSubscription; %>
                                <div class="col-md-4">
                                    <div class="border rounded p-3 h-100 <%= isCurrent ? 'border-danger border-2' : '' %>">
                                        <div class="d-flex justify-content-between align-items-start mb-1">
                                            <h6 class="mb-0 text-capitalize"><%= price.label %></h6>
                                            <% if (isCurrent) { %><span class="badge bg-success">Active</span><% } %>
                                        </div>
                                        <div class="fw-bold mb-2">Rs <%= price.amountInr %> / <%= price.durationDays %> days</div>
                                        <ul class="small text-muted ps-3 mb-3">
                                            <% benefits.forEach(function(line) { %>
                                                <li><%= line %></li>
                                            <% }); %>
                                        </ul>
                                        <button class="btn btn-<%= planKey === 'pro' ? 'danger' : 'outline-danger' %> btn-sm w-100 buy-plan-btn" data-plan="<%= planKey %>" <%= isCurrent ? 'disabled' : '' %>>
                                            <%= isCurrent ? 'Current plan' : 'Buy ' + price.label %>
                                        </button>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                        <% if (user.subscription && user.subscription.expiresAt && hasActiveSubscription) { %>
                        <div class="small text-muted mt-3">
                            Active until: <strong><%= new Date(user.subscription.expiresAt).toLocaleString() %></strong>
                        </div>
                        <% } %>
                        <% if (userAnalytics) { %>
                        <div class="border-top pt-3 mt-3">
                            <h6 class="mb-2">📊 Your analytics (Pro / Advanced)</h6>
                            <% if (user.role === 'user') { %>
                                <div class="row g-2 small">
                                    <div class="col-md-3"><div class="border rounded p-2">Requests: <strong><%= userAnalytics.totalRequests %></strong></div></div>
                                    <div class="col-md-3"><div class="border rounded p-2">Active: <strong><%= userAnalytics.activeRequests %></strong></div></div>
                                    <div class="col-md-3"><div class="border rounded p-2">Responses: <strong><%= userAnalytics.totalResponses %></strong></div></div>
                                    <div class="col-md-3"><div class="border rounded p-2">Response rate: <strong><%= userAnalytics.responseRate %>%</strong></div></div>
                                </div>
                            <% } else if (user.role === 'donor') { %>
                                <div class="row g-2 small">
                                    <div class="col-md-3"><div class="border rounded p-2">Responses: <strong><%= userAnalytics.responseCount %></strong></div></div>
                                    <div class="col-md-3"><div class="border rounded p-2">Donations: <strong><%= userAnalytics.totalDonations %></strong></div></div>
                                    <div class="col-md-3"><div class="border rounded p-2">Eligible: <strong><%= userAnalytics.eligibleNow ? 'Yes' : 'No' %></strong></div></div>
                                    <div class="col-md-3"><div class="border rounded p-2">Cooldown: <strong><%= userAnalytics.cooldownDaysRemaining %> days</strong></div></div>
                                </div>
                            <% } else if (user.role === 'bloodbank') { %>
                                <div class="row g-2 small">
                                    <div class="col-md-3"><div class="border rounded p-2">Total stock: <strong><%= userAnalytics.totalInventoryUnits %> units</strong></div></div>
                                    <div class="col-md-3"><div class="border rounded p-2">Requests contacted: <strong><%= userAnalytics.requestsContacted %></strong></div></div>
                                    <div class="col-md-3"><div class="border rounded p-2">Active emergencies: <strong><%= userAnalytics.activeEmergencies %></strong></div></div>
                                    <div class="col-md-3"><div class="border rounded p-2">Fulfilled: <strong><%= userAnalytics.fulfilledRequests %></strong></div></div>
                                </div>
                            <% } %>
                        </div>
                        <% } %>
                        <% if (canExportData) { %>
                        <div class="mt-3">
                            <a href="/export/my-data" class="btn btn-outline-dark btn-sm">⬇ Download my report (PDF) — Advanced</a>
                        </div>
                        <% } %>
                        <% const latestActiveRequest = (bloodRequests || []).find(function(r) { return ['active', 'contacted'].includes(r.status); }); %>
                        <div class="border-top pt-3 mt-3">
                            <h6 class="mb-2">One-time payments</h6>
                            <% if (user.role === 'user') { %>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div>
                                    <strong><%= oneTimePayments.request_boost.label %></strong>
                                    <div class="small text-muted">Rs <%= oneTimePayments.request_boost.amountInr %> — <%= oneTimePayments.request_boost.description %></div>
                                </div>
                                <button class="btn btn-outline-warning btn-sm pay-action-btn"
                                        data-purpose="request_boost"
                                        data-request-id="<%= latestActiveRequest ? latestActiveRequest._id : '' %>"
                                        <%= latestActiveRequest ? '' : 'disabled' %>>
                                    Boost request
                                </button>
                            </div>
                            <% } %>
                            <% if (user.role === 'donor') { %>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div>
                                    <strong><%= oneTimePayments.donor_verification.label %></strong>
                                    <div class="small text-muted">Rs <%= oneTimePayments.donor_verification.amountInr %> — <%= oneTimePayments.donor_verification.description %></div>
                                </div>
                                <button class="btn btn-outline-primary btn-sm pay-action-btn"
                                        data-purpose="donor_verification"
                                        <%= user.donorVerificationFeePaid ? 'disabled' : '' %>>
                                    <%= user.donorVerificationFeePaid ? 'Fee paid ✓' : 'Pay now' %>
                                </button>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% } %>

                <!-- PATIENT: approved donors & blood banks -->
                <% if (user.role === 'user') { %>
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-white"><h5 class="mb-0">Approved blood donors</h5></div>
                        <div class="card-body border-bottom">
                            <form class="row g-2" id="donorSearchForm">
                                <div class="col-md-3">
                                    <select name="bloodGroup" class="form-select form-select-sm">
                                        <option value="">Blood group</option>
                                        <% ['A+','A-','B+','B-','AB+','AB-','O+','O-'].forEach(function(bg) { %>
                                            <option><%= bg %></option>
                                        <% }); %>
                                    </select>
                                </div>
                                <div class="col-md-3"><input name="city" class="form-control form-control-sm" placeholder="City" value="<%= user.city %>"></div>
                                <div class="col-md-3">
                                    <select name="availability" class="form-select form-select-sm">
                                        <option value="">Any availability</option>
                                        <option value="available">Available</option>
                                        <option value="unavailable">Unavailable</option>
                                    </select>
                                </div>
                                <div class="col-md-3"><button class="btn btn-outline-danger btn-sm w-100">Search donors</button></div>
                            </form>
                            <div id="donorSearchResults" class="small mt-3"></div>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm mb-0">
                                <thead><tr><th>Name</th><th>Blood</th><th>City</th><th>Phone</th><th>Eligibility</th><th>Chat</th></tr></thead>
                                <tbody>
                                    <% if (approvedDonors && approvedDonors.length) { %>
                                        <% approvedDonors.forEach(function(d) { %>
                                            <tr>
                                                <td><%= d.userId ? d.userId.name : '—' %></td>
                                                <td><strong><%= d.bloodGroup %></strong></td>
                                                <td><%= d.userId ? d.userId.city : '—' %></td>
                                                <td><% if (d.userId) { %><a href="tel:<%= d.userId.phone %>"><%= d.userId.phone %></a><% } %></td>
                                                <td><span class="badge bg-<%= donorEligibilityBadge(d) %>"><%= donorEligibilityLabel(d) %></span></td>
                                                <td>
                                                    <% if (d.userId && d.userId._id) { %>
                                                        <button
                                                            type="button"
                                                            class="btn btn-outline-primary btn-sm chat-btn"
                                                            data-user-id="<%= d.userId._id %>"
                                                            data-user-name="<%= d.userId.name %>"
                                                            data-user-role="donor"
                                                        >Chat</button>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% } else { %>
                                        <tr><td colspan="6" class="text-center text-muted">No approved donors yet.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-white"><h5 class="mb-0">Approved blood banks</h5></div>
                        <div class="card-body border-bottom">
                            <form class="row g-2" id="bloodBankSearchForm">
                                <div class="col-md-3">
                                    <select name="bloodGroup" class="form-select form-select-sm">
                                        <option value="">Blood group</option>
                                        <% ['A+','A-','B+','B-','AB+','AB-','O+','O-'].forEach(function(bg) { %>
                                            <option><%= bg %></option>
                                        <% }); %>
                                    </select>
                                </div>
                                <div class="col-md-3"><input name="city" class="form-control form-control-sm" placeholder="City" value="<%= user.city %>"></div>
                                <div class="col-md-3"><input name="radiusKm" type="number" class="form-control form-control-sm" value="20" min="1"></div>
                                <div class="col-md-3"><button class="btn btn-outline-danger btn-sm w-100">Search banks</button></div>
                            </form>
                            <div id="bloodBankSearchResults" class="small mt-3"></div>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm mb-0">
                                <thead><tr><th>Hospital</th><th>City</th><th>Contact</th><th>Inventory (sample)</th><th>Chat</th></tr></thead>
                                <tbody>
                                    <% if (approvedBloodBanks && approvedBloodBanks.length) { %>
                                        <% approvedBloodBanks.forEach(function(bb) { %>
                                            <tr>
                                                <td><%= bb.hospitalName %></td>
                                                <td><%= bb.userId ? bb.userId.city : '—' %></td>
                                                <td><% if (bb.userId) { %><a href="tel:<%= bb.userId.phone %>"><%= bb.userId.phone %></a><% } %></td>
                                                <td class="small">O+: <%= bb.inventory['O+'] || 0 %>, A+: <%= bb.inventory['A+'] || 0 %></td>
                                                <td>
                                                    <% if (bb.userId && bb.userId._id) { %>
                                                        <button
                                                            type="button"
                                                            class="btn btn-outline-primary btn-sm chat-btn"
                                                            data-user-id="<%= bb.userId._id %>"
                                                            data-user-name="<%= bb.hospitalName %>"
                                                            data-user-role="bloodbank"
                                                        >Chat</button>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% } else { %>
                                        <tr><td colspan="5" class="text-center text-muted">No approved blood banks yet.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <% if ((recommendedDonors && recommendedDonors.length) || (nearbyBloodBanks && nearbyBloodBanks.length)) { %>
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-white"><h5 class="mb-0">Smart recommendations for latest active request</h5></div>
                            <div class="card-body">
                                <% if (recommendedDonors && recommendedDonors.length) { %>
                                    <h6>Ranked donors</h6>
                                    <ul class="list-group mb-3">
                                        <% recommendedDonors.forEach(function(item) { %>
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                <span>
                                                    <strong><%= item.donor.userId ? item.donor.userId.name : 'Donor' %></strong>
                                                    <span class="text-muted">(<%= item.donor.bloodGroup %>, <%= item.distanceKm %> km)</span>
                                                </span>
                                                <span class="d-flex align-items-center gap-2">
                                                    <span class="badge bg-danger">Score <%= item.score %></span>
                                                    <% if (item.donor.userId && item.donor.userId._id) { %>
                                                        <button type="button" class="btn btn-outline-primary btn-sm chat-btn"
                                                            data-user-id="<%= item.donor.userId._id %>"
                                                            data-user-name="<%= item.donor.userId.name %>"
                                                            data-user-role="donor">Chat</button>
                                                    <% } %>
                                                </span>
                                            </li>
                                        <% }); %>
                                    </ul>
                                <% } %>
                                <% if (nearbyBloodBanks && nearbyBloodBanks.length) { %>
                                    <h6>Nearby blood banks with stock</h6>
                                    <ul class="list-group">
                                        <% nearbyBloodBanks.forEach(function(item) { %>
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                <span><strong><%= item.bloodBank.hospitalName %></strong> <span class="text-muted">(<%= item.distanceKm %> km)</span></span>
                                                <span class="d-flex align-items-center gap-2">
                                                    <span class="badge bg-success"><%= item.availableUnits %> units</span>
                                                    <% if (item.bloodBank.userId && item.bloodBank.userId._id) { %>
                                                        <button type="button" class="btn btn-outline-primary btn-sm chat-btn"
                                                            data-user-id="<%= item.bloodBank.userId._id %>"
                                                            data-user-name="<%= item.bloodBank.hospitalName %>"
                                                            data-user-role="bloodbank">Chat</button>
                                                    <% } %>
                                                </span>
                                            </li>
                                        <% }); %>
                                    </ul>
                                <% } %>
                            </div>
                        </div>
                    <% } %>
                <% } %>

                <!-- Emergency requests (all roles) -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><%= user.role === 'user' ? 'My emergency requests' : 'Emergency blood requests' %></h4>
                        <% if (!isRequestsOnly) { %><a href="/request" class="btn btn-outline-danger btn-sm">Full list</a><% } %>
                    </div>
                    <div class="card-body">
                        <%- include('partials/blood-requests-table', { bloodRequests, user, donorProfile, bloodbank }) %>
                    </div>
                </div>

                <!-- PATIENT: create request with documents -->
                <% if (user.role === 'user') { %>
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-white"><h5 class="mb-0">Create emergency request</h5></div>
                        <div class="card-body">
                            <p class="text-muted small">Required: blood test report and doctor prescription.</p>
                                <form action="/request/create" method="POST" enctype="multipart/form-data" data-geo-form>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label>Blood group needed</label>
                                        <select name="bloodGroup" class="form-select" required>
                                            <% ['A+','A-','B+','B-','AB+','AB-','O+','O-'].forEach(function(bg) { %>
                                                <option><%= bg %></option>
                                            <% }); %>
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label>Required units</label>

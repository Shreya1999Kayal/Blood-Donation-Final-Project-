    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            const geoForms = document.querySelectorAll('[data-geo-form]');
            if (!geoForms.length) return;

            function fillGeoForms(lat, lng) {
                geoForms.forEach((form) => {
                    const latInput = form.querySelector('[data-geo-lat]');
                    const lngInput = form.querySelector('[data-geo-lng]');
                    if (latInput) latInput.value = String(lat);
                    if (lngInput) lngInput.value = String(lng);
                });
            }

            // Don't submit empty geo fields — server will use default coordinates.
            function omitGeoFields() {
                geoForms.forEach((form) => {
                    form.querySelectorAll('[data-geo-lat], [data-geo-lng]').forEach((input) => {
                        input.removeAttribute('name');
                        input.value = '';
                    });
                });
            }

            if (!navigator.geolocation) {
                omitGeoFields();
                return;
            }

            geoForms.forEach((form) => {
                form.addEventListener('submit', () => {
                    const latInput = form.querySelector('[data-geo-lat]');
                    const lngInput = form.querySelector('[data-geo-lng]');
                    const lat = (latInput?.value || '').trim();
                    const lng = (lngInput?.value || '').trim();
                    const latOk = lat && !Number.isNaN(Number(lat));
                    const lngOk = lng && !Number.isNaN(Number(lng));
                    if (!latOk || !lngOk) {
                        if (latInput) latInput.removeAttribute('name');
                        if (lngInput) lngInput.removeAttribute('name');
                    }
                });
            });

            navigator.geolocation.getCurrentPosition(
                (pos) => fillGeoForms(pos.coords.latitude, pos.coords.longitude),
                () => omitGeoFields(),
                { enableHighAccuracy: true, timeout: 10000, maximumAge: 60000 }
            );
        })();
    </script>
    <% if (flash && flash.error && ['upload_invalid_type', 'upload_file_too_large', 'upload_processing_failed'].includes(flash.error)) { %>
    <script>
        (function () {
            const map = {
                upload_invalid_type: {
                    title: 'Invalid file type',
                    text: 'Please upload only JPG, PNG, WEBP, or PDF documents.',
                },
                upload_file_too_large: {
                    title: 'File too large',
                    text: 'Each document must be 10 MB or smaller.',
                },
                upload_processing_failed: {
                    title: 'Upload failed',
                    text: 'We could not process your document. Please try again.',
                },
            };
            const cfg = map["<%= flash.error %>"];
            if (!cfg) return;
            if (window.Swal && typeof window.Swal.fire === 'function') {
                window.Swal.fire({
                    icon: 'error',
                    title: cfg.title,
                    text: cfg.text,
                    confirmButtonColor: '#dc3545',
                });
            }
        })();
    </script>
    <% } %>


            <div class="d-flex">
                <div class="toast-body" id="chatToastBody">New message received.</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <!-- ── Unread-chat floating button ─────────────────────────── -->
    <button id="chatUnreadBtn"
            class="btn btn-danger rounded-circle shadow-lg d-none"
            style="position:fixed;bottom:24px;right:24px;width:56px;height:56px;font-size:20px;z-index:1050;"
            title="Open chat">
        💬<span id="chatUnreadBadge"
                class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark"
                style="font-size:11px;">0</span>
    </button>
    <% } %>

    <% if (['donor', 'bloodbank', 'admin', 'user'].includes(user.role)) { %>
    <script src="/js/chat-presence.js"></script>
    <script>
        // ── Socket init & auth rooms ────────────────────────────────────────
        const socket = io({ transports: ['websocket', 'polling'] });
        const presenceWatcher = window.ChatPresence?.createWatcher(socket);
        const city = "<%= user.city %>";
        const currentUser = { id: "<%= user._id %>", role: "<%= user.role %>", city };

        socket.on('connect', () => {
            // Re-join user + role + city rooms on every (re)connect
            socket.emit('join_context', { userId: currentUser.id });
            socket.emit('join_city', city);
        });

        // ── Live notification helpers ───────────────────────────────────────
        function escHtml(s) {
            return (s || '').toString()
                .replace(/&/g, '&amp;').replace(/</g, '&lt;')
                .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        function pushNotification(html, cssClass) {
            const list = document.getElementById('notificationList');
            if (!list) return;
            const item = document.createElement('a');
            item.className = 'list-group-item list-group-item-action ' + (cssClass || 'list-group-item-danger');
            item.innerHTML = html;
            const placeholder = list.querySelector('.text-muted');
            if (placeholder) placeholder.remove();
            list.prepend(item);
            // cap at 30
            while (list.children.length > 30) list.removeChild(list.lastChild);
        }

        function pushSavedNotification(data) {
            const title   = escHtml(data.title   || 'Notification');
            const message = escHtml(data.message || '');
            const time    = data.createdAt
                ? new Date(data.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
                : new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            const link    = data.link || '/dashboard';
            const cssClass = {
                request  : 'list-group-item-danger',
                approval : 'list-group-item-success',
                match    : 'list-group-item-warning',
                contact  : 'list-group-item-info',
            }[data.type] || 'list-group-item-info';

            pushNotification(
                `<a class="text-decoration-none text-dark d-block" href="${link}">` +
                `<div class="d-flex justify-content-between align-items-start">` +
                `<strong>${title}</strong><small class="text-muted ms-2 text-nowrap">${time}</small></div>` +
                `<div class="small text-muted">${message}</div></a>`,
                cssClass
            );
        }

        // ── Notification events ─────────────────────────────────────────────
        socket.on('notification:new', (data) => {
            const notifUserId = data.userId ? data.userId.toString() : null;
            const forUser     = notifUserId === currentUser.id;
            const roleMatch   = Array.isArray(data.roles) && data.roles.includes(currentUser.role);
            const cityMatch   = data.city && data.city.toLowerCase() === currentUser.city.toLowerCase();
            const broadcast   = !notifUserId && (!data.roles || data.roles.length === 0) && !data.city;
            if (forUser || roleMatch || cityMatch || broadcast) pushSavedNotification(data);
        });

        socket.on('critical_alert', (data) => {
            pushNotification(
                `<div class="d-flex justify-content-between"><strong>🚨 Critical</strong><small>${new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}</small></div>` +
                `<div class="small">${escHtml(data.bloodGroup)} needed at ${escHtml(data.hospitalName)}</div>`,
                'list-group-item-danger'
            );
        });

        socket.on('request_created', (data) => {
            pushNotification(
                `<strong>🩸 New Request:</strong> ${escHtml(data.bloodGroup)} — ${escHtml(data.patientName)}`,
                'list-group-item-warning'
            );
        });
    </script>
    <% } %>

    <% if (['user', 'donor', 'bloodbank'].includes(user.role)) { %>
    <script>window.__RAZORPAY_KEY__ = <%- JSON.stringify(razorpayKeyId || '') %>;</script>
    <script src="/js/razorpay-checkout.js?v=6"></script>
    <script>
        (function () {
            function pay(payload) {
                if (window.RaktaSetuPayments) {
                    window.RaktaSetuPayments.openCheckout(payload, '#dc3545');
                }
            }

            document.querySelectorAll('.buy-plan-btn').forEach((button) => {
                button.addEventListener('click', () => {
                    const plan = button.dataset.plan;
                    if (!plan) return;
                    pay({ purpose: 'subscription', plan });
                });
            });

            document.querySelectorAll('.pay-action-btn').forEach((button) => {
                button.addEventListener('click', () => {
                    const purpose = button.dataset.purpose;
                    if (!purpose) return;
                    if (purpose === 'request_boost') {
                        const requestId = button.dataset.requestId;
                        if (!requestId) {
                            Swal.fire({
                                icon: 'warning',
                                title: 'No active request found',
                                text: 'Create an active request first, then boost it.',
                                confirmButtonColor: '#dc3545',
                            });
                            return;
                        }
                        pay({ purpose, requestId });
                        return;
                    }
                    pay({ purpose });
                });
            });
        })();
    </script>
    <% } %>

    <!-- ═══════════════════════════════════════════════════════════
         Socket.io — Chat + Live Notifications
    ════════════════════════════════════════════════════════════ -->
    <% if (['user', 'donor', 'bloodbank'].includes(user.role)) { %>
    <script>
    (function () {
        'use strict';

        // ── DOM refs ────────────────────────────────────────────────────
        const chatModalEl    = document.getElementById('chatModal');
        const chatMessagesEl = document.getElementById('chatMessages');
        const chatWithNameEl = document.getElementById('chatWithName');
        const chatForm       = document.getElementById('chatForm');
        const chatInput      = document.getElementById('chatInput');
        const toastEl        = document.getElementById('chatToast');
        const toastBodyEl    = document.getElementById('chatToastBody');
        const unreadBtn      = document.getElementById('chatUnreadBtn');
        const unreadBadgeEl  = document.getElementById('chatUnreadBadge');

        const chatModal = chatModalEl ? new bootstrap.Modal(chatModalEl) : null;
        const chatToast = toastEl    ? new bootstrap.Toast(toastEl, { delay: 4000 }) : null;

        let activeChat  = null; // { userId, name, role, conversationId }
        let unreadCount = 0;
        let modalOpen   = false;

        chatModalEl?.addEventListener('show.bs.modal',  () => { modalOpen = true; });
        chatModalEl?.addEventListener('hidden.bs.modal', () => {
            modalOpen = false;
            presenceWatcher?.unwatch();
        });

        // ── Helpers ────────────────────────────────────────────────────
        function esc(s) {
            return (s || '').toString()
                .replace(/&/g, '&amp;').replace(/</g, '&lt;')
                .replace(/>/g, '&gt;').replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        function showChatError(message) {
            const text = message || 'Chat error';
            if (window.Swal && typeof window.Swal.fire === 'function') {
                window.Swal.fire({
                    icon: 'error',
                    title: 'Chat blocked',
                    text,
                    confirmButtonColor: '#dc3545',
                });
                return;
            }
            alert(text);
        }

        function scrollDown() {
            if (chatMessagesEl) chatMessagesEl.scrollTop = chatMessagesEl.scrollHeight;
        }

        function renderBubble(msg) {
            const mine = String(msg.fromUserId) === String(currentUser.id);
            const wrap = document.createElement('div');
            wrap.className = 'd-flex align-items-end gap-2 ' + (mine ? 'flex-row-reverse' : '');

            const bubble = document.createElement('div');
            bubble.className = 'px-3 py-2 rounded-3 ' + (mine
                ? 'bg-danger text-white'
                : 'bg-white border text-dark');
            bubble.style.cssText = 'max-width:78%;word-break:break-word;font-size:.92rem;';
            const time = msg.createdAt ? new Date(msg.createdAt).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) : '';
            bubble.innerHTML =
                `<div style="white-space:pre-wrap;">${esc(msg.message || msg.text || '')}</div>` +
                `<div class="mt-1 ${mine ? 'text-white-50' : 'text-muted'}" style="font-size:.7rem;text-align:${mine?'right':'left'}">${time}</div>`;

            wrap.appendChild(bubble);
            return wrap;
        }

        // ── Unread badge ───────────────────────────────────────────────
        function incrementUnread(senderName) {
            unreadCount++;
            if (unreadBtn) {
                unreadBtn.classList.remove('d-none');
                if (unreadBadgeEl) unreadBadgeEl.textContent = unreadCount;
            }
            if (chatToast && toastBodyEl) {
                toastBodyEl.textContent = `💬 ${senderName || 'Someone'} sent you a message`;
                chatToast.show();
            }
        }

        function clearUnread() {
            unreadCount = 0;
            if (unreadBtn) unreadBtn.classList.add('d-none');
            if (unreadBadgeEl) unreadBadgeEl.textContent = '0';
        }

        // ── Open chat ──────────────────────────────────────────────────
        function openChat(userId, name, role) {
            if (!chatModal) return;
            activeChat = { userId, name, role, conversationId: null };
            if (chatWithNameEl) chatWithNameEl.textContent = `${esc(name)} · ${role}`;
            presenceWatcher?.watch(userId, document.getElementById('chatPresenceStatus'));
            if (chatMessagesEl) chatMessagesEl.innerHTML =
                '<div class="text-muted small text-center py-4">Loading messages…</div>';
            clearUnread();
            chatModal.show();

            // Request history via ack callback
            socket.emit('chat:history', { withUserId: userId, limit: 50 }, (resp) => {
                if (!resp || !resp.ok) {
                    if (chatMessagesEl)
                        chatMessagesEl.innerHTML =
                            `<div class="text-danger small text-center py-4">${esc(resp?.error || 'Unable to open chat')}</div>`;
                    return;
                }
                activeChat.conversationId = resp.conversationId;
                if (chatMessagesEl) chatMessagesEl.innerHTML = '';
                if (!resp.messages?.length) {
                    const p = document.createElement('div');
                    p.className = 'text-muted small text-center py-4';
                    p.textContent = 'No messages yet. Say hello! 👋';
                    chatMessagesEl?.appendChild(p);
                } else {
                    (resp.messages || []).forEach((m) => chatMessagesEl?.appendChild(renderBubble(m)));
                }
                scrollDown();
            });
        }

        // ── Delegate chat-btn clicks ───────────────────────────────────
        document.addEventListener('click', (e) => {
            const btn = e.target.closest('.chat-btn');
            if (!btn) return;
            const userId = btn.dataset.userId;
            const name   = btn.dataset.userName  || 'User';
            const role   = btn.dataset.userRole  || 'user';
            if (userId) openChat(userId, name, role);
        });

        // Floating unread button also opens the last conversation
        unreadBtn?.addEventListener('click', () => {
            if (activeChat?.userId) {
                clearUnread();
                chatModal?.show();
            }
        });

        // ── Send message ───────────────────────────────────────────────
        chatForm?.addEventListener('submit', (e) => {
            e.preventDefault();
            if (!activeChat?.userId) return;
            const text = (chatInput?.value || '').trim();
            if (!text) return;

            // Optimistically render sender's bubble immediately
            const optimistic = renderBubble({
                fromUserId: currentUser.id,
                toUserId:   activeChat.userId,
                message:    text,
                createdAt:  new Date(),
            });
            chatMessagesEl?.appendChild(optimistic);
            scrollDown();

            socket.emit('chat:send', {
                toUserId:       activeChat.userId,
                text,                           // server uses `text`
                conversationId: activeChat.conversationId || undefined,
            }, (resp) => {
                if (!resp || !resp.ok) {
                    // Roll back optimistic bubble
                    optimistic.remove();
                    showChatError(resp?.error || 'Failed to send message');
                }
            });

            if (chatInput) { chatInput.value = ''; chatInput.focus(); }
        });

        // ── Receive messages ───────────────────────────────────────────
        socket.on('chat:message', (msg) => {
            const fromId = String(msg.fromUserId);
            const toId   = String(msg.toUserId);
            const myId   = String(currentUser.id);

            // Skip messages I sent (already rendered optimistically)
            if (fromId === myId) return;

            // Is this for the currently open chat?
            const isActive = activeChat?.userId && (
                fromId === String(activeChat.userId) ||
                toId   === String(activeChat.userId)
            );

            if (isActive && modalOpen) {
                chatMessagesEl?.appendChild(renderBubble(msg));
                scrollDown();
            } else {
                incrementUnread(msg.senderName || 'Someone');
                // If the same user but modal closed — queue message for next open
                if (isActive && !modalOpen) {
                    // We'll just show the toast; messages load fresh on next openChat()
                }
            }
        });

        socket.on('chat:error', (err) => {
            console.warn('[chat:error]', err);
            showChatError(err?.error || 'Chat error');
        });
    })();
    </script>
    <% } %>

    <% if (user.role === 'user') { %>
    <script>
        async function submitSearch(formId, endpoint, targetId, render) {
            const form = document.getElementById(formId);
            if (!form) return;
            form.addEventListener('submit', async (event) => {
                event.preventDefault();
                const params = new URLSearchParams(new FormData(form));
                if (endpoint.includes('bloodbanks')) params.set('nearby', '1');
                const target = document.getElementById(targetId);
                target.innerHTML = 'Searching...';
                const response = await fetch(`${endpoint}?${params.toString()}`);
                const data = await response.json();
                target.innerHTML = render(data);
            });
        }

        submitSearch('donorSearchForm', '/search/donors', 'donorSearchResults', (data) => {
            const donors = data.donors || [];
            if (!donors.length) return '<span class="text-muted">No donors found.</span>';
            return donors.map((item) => {
                const donor = item.donor || item;
                const donorUser = donor.userId || {};
                const distance = item.distanceKm !== undefined ? `, ${item.distanceKm} km, score ${item.score}` : '';
                const lastDonation = donor.lastDonationDate ? new Date(donor.lastDonationDate).getTime() : 0;
                const cooldownDays = lastDonation ? Math.floor((Date.now() - lastDonation) / 86400000) : 999;
                const remaining = Math.max(0, 90 - cooldownDays);
                const eligible = donor.status === 'approved' && donor.isAvailable && remaining === 0;
                const badge = eligible ? '<span class="badge bg-success">Eligible</span>' : `<span class="badge bg-danger">Not eligible${remaining ? ` (${remaining} days left)` : ''}</span>`;
                return `<div class="border rounded p-2 mb-2"><strong>${donorUser.name || 'Donor'}</strong> (${donor.bloodGroup}${distance}) ${badge}<br><a href="tel:${donorUser.phone || ''}">${donorUser.phone || ''}</a>${donorUser._id ? `<br><button type="button" class="btn btn-outline-primary btn-sm chat-btn mt-1" data-user-id="${donorUser._id}" data-user-name="${donorUser.name || 'Donor'}" data-user-role="donor">Chat</button>` : ''}</div>`;
            }).join('');
        });

        submitSearch('bloodBankSearchForm', '/search/bloodbanks', 'bloodBankSearchResults', (data) => {
            const banks = data.bloodBanks || [];
            if (!banks.length) return '<span class="text-muted">No blood banks found.</span>';
            return banks.map((item) => {
                const bank = item.bloodBank || item;
                const bankUser = bank.userId || {};
                const stock = item.availableUnits !== undefined ? `${item.availableUnits} units, ${item.distanceKm} km` : 'Stock available';
                return `<div class="border rounded p-2 mb-2"><strong>${bank.hospitalName}</strong><br>${stock}<br><a href="tel:${bankUser.phone || ''}">${bankUser.phone || ''}</a>${bankUser._id ? `<br><button type="button" class="btn btn-outline-primary btn-sm chat-btn mt-1" data-user-id="${bankUser._id}" data-user-name="${bank.hospitalName}" data-user-role="bloodbank">Chat</button>` : ''}</div>`;
            }).join('');
        });
    </script>
    <% } %>

    <% if (user.role === 'admin' && analytics) { %>
    <script>
        const analytics = <%- JSON.stringify(analytics) %>;
        function makeChart(id, source, type) {
            const element = document.getElementById(id);
            if (!element) return;
            new Chart(element, {
                type,
                data: {
                    labels: Object.keys(source),
                    datasets: [{
                        data: Object.values(source),
                        backgroundColor: ['#dc3545', '#198754', '#ffc107', '#0d6efd', '#6c757d', '#20c997', '#6610f2', '#fd7e14'],
                    }],
                },
                options: { plugins: { legend: { position: 'bottom' } } },
            });
        }
        makeChart('donorStatusChart', analytics.donorsByStatus, 'doughnut');
        makeChart('requestUrgencyChart', analytics.requestsByUrgency, 'bar');
        makeChart('inventoryChart', analytics.inventoryTotals, 'bar');
    </script>
    <% } %>

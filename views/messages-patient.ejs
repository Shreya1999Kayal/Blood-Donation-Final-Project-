<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Messages — RaktaSetu</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="/css/admin-ui.css" rel="stylesheet">

    <link href="/css/patient-ui.css" rel="stylesheet">

    <%- include('partials/patient/tailwind-head') %>

    <script src="/socket.io/socket.io.js"></script>

</head>

<body class="admin-shell pt-shell pt-messages-page">



<div class="pt-messages-topbar">

    <div class="container-fluid px-3 px-lg-4 d-flex align-items-center gap-3">

        <a href="/dashboard#section-messages" class="btn btn-outline-danger btn-sm d-inline-flex align-items-center gap-1">

            <i data-lucide="arrow-left" style="width:14px;height:14px;"></i> Dashboard

        </a>

        <div class="flex-grow-1 min-w-0">

            <h1 class="pt-messages-page-title">Patient inbox</h1>

            <span class="pt-topbar-sub">Full-screen messaging · <%= user.city %></span>

        </div>

        <span class="pt-role-badge d-none d-md-inline">

            <i data-lucide="heart-pulse" style="width:13px;height:13px;"></i> Patient

        </span>

        <a href="/auth/logout" class="btn btn-outline-danger btn-sm d-none d-md-inline-flex">Logout</a>

    </div>

</div>



<main class="admin-content">

    <div class="container-fluid px-3 px-lg-4 py-4">

        <%- include('partials/patient/section-messages', { user, inbox, isFullPage: true }) %>

    </div>

</main>



<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

<script src="/js/patient-ui.js"></script>

<%- include('partials/shared/help-chatbot', { user }) %>

</body>

</html>


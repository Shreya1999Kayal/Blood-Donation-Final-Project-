<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Camp Dashboard — RaktaSetu</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/admin-ui.css" rel="stylesheet">
    <link href="/css/camp-ui.css" rel="stylesheet">
    <link href="/css/feedback-ui.css" rel="stylesheet">
    <link href="/css/home.css" rel="stylesheet">
    <link href="/css/dashboard-home-shell.css" rel="stylesheet">
    <%- include('partials/camp/tailwind-head') %>
    <%- include('partials/home/tailwind-head') %>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script src="/socket.io/socket.io.js"></script>
</head>
<body class="admin-shell cp-shell dashboard-home-shell">

<%- include('partials/camp/dashboard-home-chrome', { user, inbox }) %>

<div class="admin-overlay" id="cpOverlay"></div>
<%- include('partials/camp/sidebar', { user, campProfile, campDonors, campBloodBanks, inbox, notifications }) %>

<div class="admin-main">
    <header class="admin-topbar">
        <button type="button" class="admin-hamburger" id="cpHamburger" aria-label="Menu"><i data-lucide="menu" style="width:20px;height:20px;"></i></button>
        <div class="admin-topbar-title-wrap">
            <h2 id="cpPageTitle">Overview</h2>
            <span class="cp-topbar-sub">Donors · blood banks · camp coordination · messaging</span>
        </div>
        <div class="ms-auto d-flex align-items-center gap-2">
            <span class="cp-role-badge d-none d-md-inline"><i data-lucide="tent" style="width:13px;height:13px;"></i> Camp</span>
            <%- include('partials/shared/topbar-user', { user }) %>
        </div>
    </header>

    <main class="admin-content">
        <% if (flash) { %>
            <% if (flash.msg === 'camp_submitted') { %><div class="alert alert-success alert-dismissible fade show">Camp registration submitted for admin approval.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.msg === 'donor_directory_unlocked') { %><div class="alert alert-success alert-dismissible fade show">Donor directory unlocked — you can now browse the full list.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.msg === 'camp_event_created') { %><div class="alert alert-success alert-dismissible fade show">Camp event scheduled.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.msg === 'camp_event_completed') { %><div class="alert alert-success alert-dismissible fade show">Camp marked as completed.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.msg === 'camp_event_cancelled') { %><div class="alert alert-success alert-dismissible fade show">Camp event cancelled successfully.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.msg === 'camp_request_sent') { %><div class="alert alert-success alert-dismissible fade show">Participation request sent. Waiting for response.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.msg === 'contact_unlocked') { %><div class="alert alert-success alert-dismissible fade show">Contact unlocked — you can now view details and chat.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.msg === 'profile_updated') { %><div class="alert alert-success alert-dismissible fade show">Profile updated.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.msg === 'feedback_submitted') { %><div class="alert alert-success alert-dismissible fade show">Thank you! Your feedback was submitted for review.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.error === 'feedback_submit_failed') { %><div class="alert alert-danger alert-dismissible fade show">Could not submit feedback. Please try again.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.error && !['upload_invalid_type','upload_file_too_large','upload_processing_failed','camp_not_approved'].includes(flash.error)) { %><div class="alert alert-danger alert-dismissible fade show"><%= flash.error === 'event_not_scheduled' ? 'Only scheduled camps can be updated.' : flash.error === 'event_not_found' ? 'Camp event not found.' : decodeURIComponent(flash.error) %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
        <% } %>

        <div id="section-overview" class="admin-panel-section active"><%- include('partials/camp/section-overview', { user, campProfile, campEvents, campDonors, campBloodBanks, campUnlockFees, campDonorDirectoryAccess }) %></div>
        <div id="section-donors" class="admin-panel-section"><%- include('partials/camp/section-donors', { campDonors, campProfile, campUnlockFees, campDonorDirectoryAccess, campDonorDirectoryCount, campScheduledEvent }) %></div>
        <div id="section-bloodbanks" class="admin-panel-section"><%- include('partials/camp/section-bloodbanks', { campBloodBanks, campProfile, campUnlockFees, campScheduledEvent }) %></div>
        <div id="section-organize" class="admin-panel-section"><%- include('partials/camp/section-organize', { user, campProfile, campStates, approvedBloodBanksForCamp, districtsByState }) %></div>
        <div id="section-history" class="admin-panel-section"><%- include('partials/camp/section-history', { campEvents }) %></div>
        <div id="section-payments" class="admin-panel-section"><%- include('partials/camp/section-payments', { campPayments, campPaymentSummary, campUnlockFees }) %></div>
        <div id="section-messages" class="admin-panel-section"><%- include('partials/camp/section-messages', { inbox }) %></div>
        <div id="section-notifications" class="admin-panel-section"><%- include('partials/camp/section-notifications', { notifications }) %></div>
        <div id="section-profile" class="admin-panel-section"><%- include('partials/camp/section-profile', { user, campProfile }) %></div>
        <div id="section-feedback" class="admin-panel-section"><%- include('partials/shared/section-feedback', { user, userFeedback, feedbackRoleLabels, feedbackCategoryLabels, feedbackPrefix: 'cp' }) %></div>
        <div id="section-password" class="admin-panel-section"><%- include('partials/camp/section-password', { user, flash }) %></div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script>window.__RAZORPAY_KEY__ = <%- JSON.stringify(razorpayKeyId || '') %>;</script>
<script>window.__CAMP_DISTRICTS__ = <%- JSON.stringify(districtsByState || {}) %>;</script>
<script src="/js/camp-ui.js"></script>
<script src="/js/change-password-form.js"></script>
<script src="/js/feedback-ui.js"></script>
<script src="/js/profile-photo-preview.js"></script>
<script src="/js/razorpay-checkout.js?v=6"></script>
<script>
    const socket = io({ transports: ['websocket', 'polling'] });
    socket.emit('join', { userId: '<%= user._id %>', role: '<%= user.role %>', city: '<%= user.city %>' });
</script>
</body>
</html>

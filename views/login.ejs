<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — RaktaSetu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/home.css" rel="stylesheet">
    <link href="/css/auth-pages.css?v=2" rel="stylesheet">
    <%- include('partials/home/tailwind-head') %>
</head>
<body>
<div class="auth-page-shell home-shell min-h-screen">
    <%- include('partials/home/topbar', { user: typeof user !== 'undefined' ? user : null }) %>
    <nav class="auth-mini-nav home-subnav" aria-label="Quick links">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center gap-1 overflow-x-auto">
                <a href="/" class="home-subnav-link">Home</a>
                <a href="/auth/login" class="home-subnav-link active">Login</a>
                <a href="/auth/register" class="home-subnav-link">Register</a>
                <a href="/#find-blood" class="home-subnav-link">Find Blood</a>
            </div>
        </div>
    </nav>

    <div class="auth-page-bg">
        <div class="auth-card">
            <div class="auth-card-head">
                <span class="auth-brand-pill">Member sign in</span>
                <h1 class="mt-3">Welcome back</h1>
                <p>Sign in to your donor, patient, blood bank, or camp account</p>
            </div>
            <div class="auth-card-body">
                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="alert alert-success py-2"><%= success %></div>
                <% } %>
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger py-2"><%= error %></div>
                <% } %>
                <% if (typeof verifyEmail !== 'undefined' && verifyEmail) { %>
                    <p class="small text-center mb-2">
                        <a href="/auth/verify-email?email=<%= encodeURIComponent(verifyEmail) %>">Verify your email</a>
                    </p>
                <% } %>
                <% if (typeof verifyPhone !== 'undefined' && verifyPhone) { %>
                    <p class="small text-center mb-2">
                        <a href="/auth/verify-phone?email=<%= encodeURIComponent(verifyPhone) %>">Verify your phone</a>
                    </p>
                <% } %>
                <p class="text-muted small text-center mb-4">Verify <strong>phone (SMS)</strong> and <strong>email</strong> before your first login.</p>
                <form action="/auth/login" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" required>
                    </div>
                    <button type="submit" class="btn btn-brand w-100">Login</button>
                </form>
                <p class="text-center mt-3 mb-1"><a href="/auth/forgot-password">Forgot password?</a></p>
                <p class="text-center mb-0">Don't have an account? <a href="/auth/register">Register</a></p>
            </div>
        </div>
    </div>
</div>
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script>if (typeof lucide !== 'undefined') lucide.createIcons();</script>
<%- include('partials/shared/help-chatbot', { user: typeof user !== 'undefined' ? user : null }) %>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patient Dashboard — RaktaSetu</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/admin-ui.css" rel="stylesheet">
    <link href="/css/patient-ui.css" rel="stylesheet">
    <link href="/css/feedback-ui.css" rel="stylesheet">
    <link href="/css/home.css" rel="stylesheet">
    <link href="/css/dashboard-home-shell.css" rel="stylesheet">
    <%- include('partials/patient/tailwind-head') %>
    <%- include('partials/home/tailwind-head') %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script src="/socket.io/socket.io.js"></script>
</head>
<body class="admin-shell pt-shell dashboard-home-shell">

<%- include('partials/patient/dashboard-home-chrome', { user, bloodRequests, inbox }) %>

<%
const ptMessageNotifCount = (notifications || []).filter(function(n) {
    return n.type === 'message' || n.type === 'contact' || (n.link && String(n.link).indexOf('/chat/') === 0);
}).length;
const notifMetaMap = getNotificationMetaMap();
%>
<div class="admin-overlay" id="ptOverlay"></div>

<%- include('partials/patient/sidebar', { user, bloodRequests, inbox, notifications, userAnalytics }) %>

<div class="admin-main">
    <header class="admin-topbar">
        <button type="button" class="admin-hamburger" id="ptHamburger" aria-label="Menu">
            <i data-lucide="menu" style="width:20px;height:20px;"></i>
        </button>
        <div class="admin-topbar-title-wrap">
            <h2 id="ptPageTitle">Overview</h2>
            <span class="pt-topbar-sub">Emergency requests · donors · blood banks · messaging</span>
        </div>
        <div class="ms-auto d-flex align-items-center gap-2">
            <span class="pt-role-badge d-none d-md-inline">
                <i data-lucide="heart-pulse" style="width:13px;height:13px;"></i> Patient
            </span>
            <a href="#" class="btn btn-outline-danger btn-sm d-none d-md-inline-flex align-items-center gap-1 position-relative" data-pt-section="notifications" data-pt-label="Notifications">
                <i data-lucide="bell" style="width:14px;height:14px;"></i> Alerts
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" id="ptTopbarNotifBadge">0</span>
            </a>
            <a href="#" class="btn btn-outline-danger btn-sm d-none d-md-inline-flex align-items-center gap-1" data-pt-section="messages" data-pt-label="Messages">
                <i data-lucide="messages-square" style="width:14px;height:14px;"></i> Messages
            </a>
            <%- include('partials/shared/topbar-user', { user }) %>
        </div>
    </header>

    <main class="admin-content">
        <% if (typeof flash !== 'undefined' && flash) { %>
            <% if (flash.msg === 'request_created') { %><div class="alert alert-success alert-dismissible fade show">Emergency request posted successfully.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.msg === 'marked_received') { %><div class="alert alert-success alert-dismissible fade show">Request marked as received.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.msg === 'profile_updated') { %><div class="alert alert-success alert-dismissible fade show">Profile updated.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.msg === 'subscription_activated') { %><div class="alert alert-success alert-dismissible fade show">Subscription activated successfully.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.msg === 'payment_success') { %><div class="alert alert-success alert-dismissible fade show">Payment recorded successfully.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.msg === 'feedback_submitted') { %><div class="alert alert-success alert-dismissible fade show">Thank you! Your feedback was submitted for review.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.error === 'feedback_submit_failed') { %><div class="alert alert-danger alert-dismissible fade show">Could not submit feedback. Please try again.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.error === 'patient_docs_required') { %><div class="alert alert-danger alert-dismissible fade show">Upload blood test report and prescription to create a request.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.error === 'request_closed') { %><div class="alert alert-warning alert-dismissible fade show">This request is already closed.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.error === 'already_received') { %><div class="alert alert-info alert-dismissible fade show">Request already marked as received.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.error === 'select_responder') { %><div class="alert alert-warning alert-dismissible fade show">Select the donor or blood bank that provided blood before marking received.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
            <% if (flash.error && !['patient_docs_required','request_closed','already_received','select_responder','upload_invalid_type','upload_file_too_large','upload_processing_failed'].includes(flash.error)) { %><div class="alert alert-danger alert-dismissible fade show"><%= flash.error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
        <% } %>

        <div id="section-overview" class="admin-panel-section active">
            <%- include('partials/patient/section-overview', { user, bloodRequests, inbox, userAnalytics }) %>
        </div>
        <div id="section-create-request" class="admin-panel-section">
            <%- include('partials/patient/section-create-request', { user }) %>
        </div>
        <div id="section-requests" class="admin-panel-section">
            <%- include('partials/patient/section-requests', { bloodRequests, user }) %>
        </div>
        <div id="section-donors" class="admin-panel-section">
            <%- include('partials/patient/section-donors', { user, approvedDonors, bloodRequests }) %>
        </div>
        <div id="section-bloodbanks" class="admin-panel-section">
            <%- include('partials/patient/section-bloodbanks', { user, approvedBloodBanks, bloodRequests }) %>
        </div>
        <div id="section-matches" class="admin-panel-section">
            <%- include('partials/patient/section-matches', { bloodRequests, recommendedDonors, nearbyBloodBanks }) %>
        </div>
        <div id="section-messages" class="admin-panel-section">
            <%- include('partials/patient/section-messages', { user, inbox }) %>
        </div>
        <div id="section-subscription" class="admin-panel-section">
            <%- include('partials/patient/section-subscription', { user, planBenefits, planPrices, hasActiveSubscription, canExportData, oneTimePayments, bloodRequests }) %>
        </div>
        <% if (userAnalytics) { %>
        <div id="section-analytics" class="admin-panel-section">
            <%- include('partials/patient/section-analytics', { user, userAnalytics, canExportData }) %>
        </div>
        <% } %>
        <div id="section-notifications" class="admin-panel-section">
            <%- include('partials/patient/section-notifications', { notifications, user, bloodRequests }) %>
        </div>
        <div id="section-profile" class="admin-panel-section">
            <%- include('partials/patient/section-profile', { user }) %>
        </div>
        <div id="section-feedback" class="admin-panel-section">
            <%- include('partials/shared/section-feedback', { user, userFeedback, feedbackRoleLabels, feedbackCategoryLabels, feedbackPrefix: 'pt' }) %>
        </div>
        <div id="section-password" class="admin-panel-section">
            <%- include('partials/patient/section-password', { user, flash }) %>
        </div>
    </main>
</div>

<div class="modal fade" id="chatModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable" style="max-width:520px">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-semibold">
                    <span id="chatWithName">—</span>
                    <span id="chatPresenceStatus" class="chat-presence is-offline d-block mt-1">Offline</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body bg-light" id="chatMessages" style="min-height:300px;max-height:55vh;overflow-y:auto;display:flex;flex-direction:column;gap:8px;"></div>
            <div class="modal-footer bg-white">
                <form id="chatForm" class="w-100 d-flex gap-2">
                    <input id="chatInput" class="form-control" placeholder="Type a message…" autocomplete="off" maxlength="2000" />
                    <button class="btn btn-danger px-4" type="submit">Send</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:1100">
    <div id="chatToast" class="toast align-items-center text-bg-danger border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="chatToastBody">New message received.</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<button id="chatUnreadBtn" class="btn btn-danger rounded-circle shadow-lg d-none pt-chat-fab" title="Open chat">
    <i data-lucide="messages-square" style="width:22px;height:22px;"></i>
    <span id="chatUnreadBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark">0</span>
</button>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script src="/js/geo-search.js"></script>
<script src="/js/patient-ui.js"></script>
<script src="/js/change-password-form.js"></script>
<script src="/js/feedback-ui.js"></script>
<script src="/js/profile-photo-preview.js"></script>
<script>window.__RAZORPAY_KEY__ = <%- JSON.stringify(razorpayKeyId || '') %>;</script>
<script src="/js/razorpay-checkout.js?v=6"></script>
<script src="/js/chat-presence.js"></script>

<script>
    const socket = io({ transports: ['websocket', 'polling'] });
    const presenceWatcher = window.ChatPresence?.createWatcher(socket);
    const city = "<%= user.city %>";
    const currentUser = { id: "<%= user._id %>", role: "<%= user.role %>", city };
    const initialMessageNotifCount = <%= ptMessageNotifCount %>;
    const NOTIF_META = <%- JSON.stringify(notifMetaMap) %>;

    function escHtml(s) {
        return (s || '').toString()
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function roleDisplay(role) {
        if (role === 'donor') return 'Donor';
        if (role === 'bloodbank') return 'Blood bank';
        if (role === 'user') return 'Patient';
        return role || 'Contact';
    }

    function parseChatLink(link, title) {
        if (!link || link.indexOf('/chat/') !== 0) return null;
        const userId = link.replace('/chat/', '').split('?')[0].trim();
        if (!/^[a-f0-9]{24}$/i.test(userId)) return null;
        const nameMatch = (title || '').match(/^New message from (.+)$/i);
        return {
            userId: userId,
            name: nameMatch ? nameMatch[1] : 'Contact',
            role: 'donor',
        };
    }

    function normalizeNotifType(type) {
        if (type === 'contact') return 'message';
        return type || 'system';
    }

    function notifFilterType(type) {
        const t = normalizeNotifType(type);
        if (t === 'request' || t === 'critical') return t;
        if (t === 'message') return 'message';
        if (t === 'match') return 'match';
        if (t === 'approval' || t === 'received') return 'approval';
        return 'system';
    }

    function pushNotification(opts) {
        const list = document.getElementById('notificationList');
        if (!list) return;
        const title = escHtml(opts.title || 'Notification');
        const message = escHtml(opts.message || '');
        const type = normalizeNotifType(opts.type || 'system');
        const href = opts.link || '/dashboard';
        const time = opts.time || new Date().toLocaleString([], { dateStyle: 'medium', timeStyle: 'short' });
        const chatMeta = parseChatLink(href, opts.title);
        const m = NOTIF_META[type] || NOTIF_META.system;
        const filterType = notifFilterType(type);
        const search = [opts.title, opts.message, m.label].filter(Boolean).join(' ').toLowerCase().replace(/"/g, '');
        const placeholder = document.getElementById('notifPlaceholder');
        if (placeholder) placeholder.remove();
        const item = document.createElement('a');
        item.href = chatMeta ? '#' : href;
        item.className = 'nt-card nt-card-' + m.tone + ' nt-card-live';
        item.dataset.notifItem = '';
        item.dataset.type = filterType;
        item.dataset.when = 'today';
        item.dataset.search = search;
        if (chatMeta) {
            item.dataset.chatOpen = '1';
            item.dataset.chatUserId = chatMeta.userId;
            item.dataset.chatUserName = chatMeta.name;
            item.dataset.chatUserRole = chatMeta.role;
        }
        item.innerHTML =
            '<div class="nt-card-thumb"><img src="' + m.img + '" alt="" loading="lazy">' +
            '<span class="nt-type-icon"><i data-lucide="' + m.icon + '" style="width:16px;height:16px;"></i></span></div>' +
            '<div class="nt-card-body"><div class="nt-card-head"><div>' +
            '<span class="nt-type-badge nt-type-' + m.tone + '">' + m.label + '</span>' +
            '<h6 class="nt-title">' + title + '</h6></div>' +
            '<time class="nt-time">' + escHtml(time) + '</time></div>' +
            '<p class="nt-message mb-0">' + message + '</p></div>' +
            '<div class="nt-card-arrow"><i data-lucide="chevron-right" style="width:18px;height:18px;"></i></div>';
        list.prepend(item);
        if (typeof lucide !== 'undefined') lucide.createIcons();
        if (typeof window.applyNtFilters === 'function') window.applyNtFilters();
        const feedCount = document.getElementById('ntFeedCount');
        const feedTotal = document.getElementById('ntFeedTotal');
        const count = list.querySelectorAll('[data-notif-item]').length;
        if (feedCount) feedCount.textContent = String(count);
        if (feedTotal) feedTotal.textContent = String(count);
    }

    socket.on('connect', () => {
        socket.emit('join_context', { userId: currentUser.id });
        socket.emit('join_city', city);
        const status = document.getElementById('ntConnStatus');
        if (status) { status.textContent = 'Live'; status.className = 'text-success'; }
    });

    socket.on('disconnect', () => {
        const status = document.getElementById('ntConnStatus');
        if (status) { status.textContent = 'Offline'; status.className = 'text-warning'; }
    });

    function patientShouldShowSocketAlert(data, kind) {
        if (currentUser.role !== 'user') return kind !== 'patient_only';
        if (kind === 'new_blood_request') return false;
        if (kind === 'donor_matched' || kind === 'request_resolved') {
            return data.requestedBy && String(data.requestedBy) === String(currentUser.id);
        }
        if (kind === 'notification') {
            const uid = data.userId ? String(data.userId) : null;
            return uid === String(currentUser.id);
        }
        return false;
    }

    socket.on('notification:new', (data) => {
        if (currentUser.role === 'user') {
            if (!patientShouldShowSocketAlert(data, 'notification')) return;
        } else {
            const notifUserId = data.userId ? String(data.userId) : null;
            if (notifUserId && notifUserId !== String(currentUser.id)) {
                const roles = data.roles || [];
                const matchesRole = roles.includes(currentUser.role);
                const matchesCity = data.type === 'request' && data.city && data.city === city;
                if (!matchesRole && !matchesCity) return;
            }
        }
        pushNotification({
            title: data.title || 'Notification',
            message: data.message || '',
            type: data.type || 'system',
            link: data.link || '/dashboard#section-notifications',
        });
    });

    socket.on('new_blood_request', (data) => {
        if (currentUser.role === 'user') return;
        pushNotification({
            title: 'New blood request posted',
            message: (data.bloodGroup || '') + ' needed at ' + (data.hospitalName || 'hospital') + (data.city ? ' · ' + data.city : ''),
            type: 'request',
            link: '/dashboard#section-requests',
        });
    });

    socket.on('donor_matched', (data) => {
        if (currentUser.role === 'user') return;
        if (currentUser.role === 'donor' || currentUser.role === 'bloodbank') {
            pushNotification({
                title: 'Matching update',
                message: (data.bloodGroup || 'Blood') + ' request at ' + (data.hospitalName || 'hospital') + ' — ' + (data.matchedDonors || 0) + ' donor slot(s) ranked.',
                type: 'match',
                link: '/dashboard#section-requests',
            });
        }
    });

    socket.on('request_resolved', (data) => {
        if (currentUser.role === 'user') return;
        pushNotification({
            title: 'Request resolved',
            message: (data.bloodGroup || '') + ' request at ' + (data.hospitalName || 'hospital') + ' was marked received.',
            type: 'received',
            link: '/dashboard#section-requests',
        });
    });
</script>

<script>
(function () {
    'use strict';
    const chatModalEl = document.getElementById('chatModal');
    const chatMessagesEl = document.getElementById('chatMessages');
    const chatWithNameEl = document.getElementById('chatWithName');
    const chatForm = document.getElementById('chatForm');
    const chatInput = document.getElementById('chatInput');
    const toastEl = document.getElementById('chatToast');
    const toastBodyEl = document.getElementById('chatToastBody');
    const unreadBtn = document.getElementById('chatUnreadBtn');
    const unreadBadgeEl = document.getElementById('chatUnreadBadge');
    const chatModal = chatModalEl ? new bootstrap.Modal(chatModalEl) : null;
    const chatToast = toastEl ? new bootstrap.Toast(toastEl, { delay: 5000 }) : null;
    let activeChat = null;
    let lastIncomingChat = null;
    let unreadMessageCount = typeof initialMessageNotifCount === 'number' ? initialMessageNotifCount : 0;
    let modalOpen = false;

    function roleDisplay(role) {
        if (role === 'donor') return 'Donor';
        if (role === 'bloodbank') return 'Blood bank';
        return role || 'Contact';
    }

    chatModalEl?.addEventListener('show.bs.modal', () => { modalOpen = true; });
    chatModalEl?.addEventListener('hidden.bs.modal', () => {
        modalOpen = false;
        presenceWatcher?.unwatch();
    });

    function esc(s) {
        return (s || '').toString().replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function updateMessageBadges() {
        ['notifBadge', 'ptNotifBadge', 'ptTopbarNotifBadge'].forEach(function (id) {
            const el = document.getElementById(id);
            if (!el) return;
            if (unreadMessageCount > 0) {
                el.textContent = String(unreadMessageCount);
                el.style.display = 'inline';
                el.classList.remove('d-none');
            } else {
                el.textContent = '0';
                el.style.display = 'none';
                el.classList.add('d-none');
            }
        });
        if (unreadBadgeEl) unreadBadgeEl.textContent = String(unreadMessageCount);
        unreadBtn?.classList.toggle('d-none', unreadMessageCount === 0);
    }

    function showNewMessageAlert(senderName, senderId, senderRole) {
        unreadMessageCount += 1;
        if (senderId) {
            lastIncomingChat = {
                userId: String(senderId),
                name: senderName || 'Contact',
                role: senderRole || 'donor',
            };
        }
        updateMessageBadges();
        if (chatToast && toastBodyEl) {
            toastBodyEl.textContent = senderName
                ? 'New message received from ' + senderName
                : 'New message received';
            chatToast.show();
        }
    }

    window.ptClearMessageAlerts = function () {
        unreadMessageCount = 0;
        lastIncomingChat = null;
        updateMessageBadges();
    };

    function showChatError(message) {
        if (window.Swal) Swal.fire({ icon: 'error', title: 'Cannot open chat', text: message || 'Chat error', confirmButtonColor: '#dc3545' });
        else alert(message);
    }

    function scrollDown() {
        if (chatMessagesEl) chatMessagesEl.scrollTop = chatMessagesEl.scrollHeight;
    }

    function renderBubble(msg) {
        const mine = String(msg.fromUserId) === String(currentUser.id);
        const wrap = document.createElement('div');
        wrap.className = 'd-flex align-items-end gap-2 ' + (mine ? 'flex-row-reverse' : '');
        const bubble = document.createElement('div');
        bubble.className = 'px-3 py-2 rounded-3 ' + (mine ? 'bg-danger text-white' : 'bg-white border text-dark');
        bubble.style.cssText = 'max-width:78%;word-break:break-word;font-size:.92rem;';
        const time = msg.createdAt ? new Date(msg.createdAt).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) : '';
        bubble.innerHTML = '<div style="white-space:pre-wrap;">' + esc(msg.message || msg.text || '') + '</div>' +
            '<div class="mt-1 ' + (mine ? 'text-white-50' : 'text-muted') + '" style="font-size:.7rem;">' + time + '</div>';
        wrap.appendChild(bubble);
        return wrap;
    }

    function clearUnread() {
        unreadMessageCount = 0;
        lastIncomingChat = null;
        updateMessageBadges();
    }

    function openChat(userId, name, role) {
        if (!chatModal || !userId) return;
        if (!/^[a-f0-9]{24}$/i.test(String(userId))) {
            showChatError('Invalid chat link. Open Messages and select the conversation from your inbox.');
            return;
        }
        activeChat = { userId: String(userId), name, role, conversationId: null };
        if (chatWithNameEl) chatWithNameEl.textContent = name + ' · ' + roleDisplay(role);
        presenceWatcher?.watch(userId, document.getElementById('chatPresenceStatus'));
        if (chatMessagesEl) chatMessagesEl.innerHTML = '<div class="text-muted small text-center py-4">Loading messages…</div>';
        clearUnread();
        chatModal.show();
        socket.emit('chat:history', { withUserId: userId, limit: 50 }, (resp) => {
            if (!resp || !resp.ok) {
                if (chatMessagesEl) chatMessagesEl.innerHTML = '<div class="text-danger small text-center py-4">' + esc(resp?.error || 'Unable to open chat') + '</div>';
                return;
            }
            activeChat.conversationId = resp.conversationId;
            if (chatMessagesEl) chatMessagesEl.innerHTML = '';
            if (!resp.messages?.length) {
                const p = document.createElement('div');
                p.className = 'text-muted small text-center py-4';
                p.textContent = 'No messages yet. Say hello!';
                chatMessagesEl?.appendChild(p);
            } else {
                resp.messages.forEach((m) => chatMessagesEl?.appendChild(renderBubble(m)));
            }
            scrollDown();
        });
    }

    window.ptOpenChat = openChat;

    document.getElementById('notificationList')?.addEventListener('click', function (e) {
        const card = e.target.closest('[data-chat-open]');
        if (!card) return;
        e.preventDefault();
        openChat(card.dataset.chatUserId, card.dataset.chatUserName || 'Contact', card.dataset.chatUserRole || 'donor');
    });

    document.addEventListener('click', (e) => {
        const btn = e.target.closest('.chat-btn');
        if (!btn) return;
        e.preventDefault();
        openChat(btn.dataset.userId, btn.dataset.userName || 'User', btn.dataset.userRole || 'donor');
    });

    unreadBtn?.addEventListener('click', () => {
        const target = lastIncomingChat || activeChat;
        if (target?.userId) openChat(target.userId, target.name, target.role);
    });

    chatForm?.addEventListener('submit', (e) => {
        e.preventDefault();
        if (!activeChat?.userId) return;
        const text = (chatInput?.value || '').trim();
        if (!text) return;
        const optimistic = renderBubble({ fromUserId: currentUser.id, message: text, createdAt: new Date() });
        chatMessagesEl?.appendChild(optimistic);
        scrollDown();
        socket.emit('chat:send', { toUserId: activeChat.userId, text, conversationId: activeChat.conversationId || undefined }, (resp) => {
            if (!resp || !resp.ok) { optimistic.remove(); showChatError(resp?.error || 'Failed to send message'); return; }
            if (typeof window.ptReloadInbox === 'function') window.ptReloadInbox();
        });
        if (chatInput) { chatInput.value = ''; chatInput.focus(); }
    });

    socket.on('chat:message', (msg) => {
        if (String(msg.fromUserId) === String(currentUser.id)) return;
        const isActive = activeChat?.userId && (String(msg.fromUserId) === String(activeChat.userId) || String(msg.toUserId) === String(activeChat.userId));
        if (isActive && modalOpen) {
            chatMessagesEl?.appendChild(renderBubble(msg));
            scrollDown();
        } else {
            showNewMessageAlert(msg.senderName || 'Someone', msg.fromUserId, msg.senderRole || 'donor');
        }
    });

    const prevShowSection = window.ptShowSection;
    window.ptShowSection = function (id, label) {
        if (typeof prevShowSection === 'function') prevShowSection(id, label);
        if (id === 'notifications') ptClearMessageAlerts();
    };

    const onNotificationsSection =
        window.location.hash === '#section-notifications'
        || document.getElementById('section-notifications')?.classList.contains('active');

    if (onNotificationsSection) {
        ptClearMessageAlerts();
    } else {
        updateMessageBadges();
    }
})();
</script>

<% if (flash && flash.error && ['upload_invalid_type', 'upload_file_too_large', 'upload_processing_failed'].includes(flash.error)) { %>
<script>
(function () {
    const map = {
        upload_invalid_type: { title: 'Invalid file type', text: 'Please upload only JPG, PNG, WEBP, or PDF documents.' },
        upload_file_too_large: { title: 'File too large', text: 'Each document must be 10 MB or smaller.' },
        upload_processing_failed: { title: 'Upload failed', text: 'We could not process your document. Please try again.' },
    };
    const cfg = map["<%= flash.error %>"];
    if (cfg && window.Swal) Swal.fire({ icon: 'error', title: cfg.title, text: cfg.text, confirmButtonColor: '#dc3545' });
})();
</script>
<% } %>

<%- include('partials/shared/help-chatbot', { user }) %>

</body>
</html>

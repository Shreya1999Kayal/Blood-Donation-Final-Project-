<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login — RaktaSetu</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/admin-ui.css" rel="stylesheet">
    <link href="/css/admin-auth-pages.css" rel="stylesheet">
</head>
<body class="admin-auth-shell">
    <header class="admin-auth-header">
        <a href="/admin/login" class="admin-auth-brand">
            <div class="admin-auth-brand-mark">
                <i data-lucide="shield" style="width:22px;height:22px;color:#fff;"></i>
            </div>
            <div>
                <h1>RaktaSetu</h1>
                <p>Platform administration</p>
            </div>
        </a>
        <span class="admin-auth-badge"><i data-lucide="shield-check" style="width:14px;height:14px;"></i> Admin portal</span>
    </header>

    <main class="admin-auth-main">
        <div class="admin-auth-card">
            <div class="admin-auth-card-head">
                <h2>Admin login</h2>
                <p>Sign in to manage users, donors, blood banks, and emergencies</p>
            </div>
            <div class="admin-auth-card-body">
                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="alert alert-success py-2"><%= success %></div>
                <% } %>
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger py-2"><%= error %></div>
                <% } %>
                <% if (typeof verifyEmail !== 'undefined' && verifyEmail) { %>
                    <p class="small text-center mb-2">
                        <a href="/auth/verify-email?email=<%= encodeURIComponent(verifyEmail) %>&portal=admin">Verify your email</a>
                    </p>
                <% } %>
                <% if (typeof verifyPhone !== 'undefined' && verifyPhone) { %>
                    <p class="small text-center mb-2">
                        <a href="/auth/verify-phone?email=<%= encodeURIComponent(verifyPhone) %>&portal=admin">Verify your phone</a>
                    </p>
                <% } %>
                <p class="text-muted small text-center mb-4">Admin accounts require verified phone and email before login.</p>
                <form action="/admin/login" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" required>
                    </div>
                    <button type="submit" class="btn btn-admin w-100">Sign in to admin dashboard</button>
                </form>
                <div class="admin-auth-footer-links">
                    <p class="mb-1">Need an admin account? <a href="/admin/registration">Register here</a></p>
                    <p class="mb-0"><a href="/auth/login">Main site login</a></p>
                </div>
            </div>
        </div>
    </main>

    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <script>if (typeof lucide !== 'undefined') lucide.createIcons();</script>
    <%- include('partials/shared/help-chatbot', { user: typeof user !== 'undefined' ? user : null }) %>
</body>
</html>

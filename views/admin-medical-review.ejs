<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Medical review — <%= donorUser?.name || 'Donor' %> | RaktaSetu Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/admin-ui.css" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="admin-shell bg-light">
<div class="container py-4 py-lg-5" style="max-width: 960px;">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <a href="/dashboard#section-donors" class="btn btn-sm btn-outline-secondary mb-2">&larr; Back to donors</a>
            <h1 class="h3 mb-1">AI medical review</h1>
            <p class="text-muted mb-0"><%= donorUser?.name || 'Donor' %> · <%= donor.bloodGroup %> · <%= donor.status %></p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <form action="/admin/donor/<%= donor._id %>/approve" method="POST">
                <button type="submit" class="btn btn-success btn-sm" <%= donor.status === 'approved' ? 'disabled' : '' %>>Approve</button>
            </form>
            <form action="/admin/donor/<%= donor._id %>/reject" method="POST">
                <button type="submit" class="btn btn-outline-danger btn-sm" <%= donor.status === 'rejected' ? 'disabled' : '' %>>Reject</button>
            </form>
            <button type="button" class="btn btn-outline-primary btn-sm" id="reanalyzeBtn">Re-run AI analysis</button>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white"><strong>Donor profile</strong></div>
                <div class="card-body small">
                    <p class="mb-1"><strong>Email:</strong> <%= donorUser?.email || '—' %></p>
                    <p class="mb-1"><strong>Phone:</strong> <%= donorUser?.phone || '—' %></p>
                    <p class="mb-1"><strong>City:</strong> <%= donorUser?.city || '—' %></p>
                    <p class="mb-1"><strong>Selected blood group:</strong> <%= donor.bloodGroup %></p>
                    <p class="mb-0"><strong>Submitted:</strong> <%= new Date(donor.createdAt).toLocaleString() %></p>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>AI screening output</strong>
                    <span class="badge bg-<%= ai.eligibility === 'Recommended' ? 'success' : ai.eligibility === 'Not Recommended' ? 'danger' : 'warning' %>"><%= ai.eligibility || 'Pending' %></span>
                </div>
                <div class="card-body">
                    <div class="row g-3 mb-3">
                        <div class="col-sm-4"><div class="border rounded p-2 text-center"><small class="text-muted d-block">Risk score</small><strong class="fs-4"><%= ai.riskScore != null ? ai.riskScore : '—' %></strong></div></div>
                        <div class="col-sm-4"><div class="border rounded p-2 text-center"><small class="text-muted d-block">Extracted group</small><strong><%= ai.extractedBloodGroup || '—' %></strong></div></div>
                        <div class="col-sm-4"><div class="border rounded p-2 text-center"><small class="text-muted d-block">Mismatch</small><strong class="<%= ai.bloodGroupMismatch ? 'text-danger' : 'text-success' %>"><%= ai.bloodGroupMismatch ? 'Yes' : 'No' %></strong></div></div>
                    </div>
                    <% if (ai.detectedDiseases && ai.detectedDiseases.length) { %>
                    <p class="mb-2"><strong>Detected flags:</strong> <%= ai.detectedDiseases.join(', ') %></p>
                    <% } %>
                    <% if (ai.analysisSummary) { %><p class="mb-2"><strong>Summary:</strong> <%= ai.analysisSummary %></p><% } %>
                    <% if (ai.analysisNotes) { %><p class="mb-2 text-muted small"><strong>Notes:</strong> <%= ai.analysisNotes %></p><% } %>
                    <p class="mb-0 small text-muted">Provider: <%= ai.analysisProvider || 'rules' %><% if (ai.analyzedAt) { %> · <%= new Date(ai.analyzedAt).toLocaleString() %><% } %></p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mt-4">
        <div class="card-header bg-white"><strong>OCR excerpts</strong></div>
        <div class="card-body">
            <% const excerpts = ai.ocrExcerpts || {}; %>
            <% const docLabels = { bloodGroupReport: 'Blood group report', bloodTestReport: 'Blood test report', fitnessCertificate: 'Fitness certificate', identityProof: 'Identity proof', combined: 'Combined text' }; %>
            <% Object.keys(docLabels).forEach(function(key) { %>
                <% if (excerpts[key]) { %>
                <div class="mb-3">
                    <h6 class="small text-uppercase text-muted"><%= docLabels[key] %></h6>
                    <pre class="bg-light border rounded p-3 small mb-0" style="white-space: pre-wrap; max-height: 180px; overflow:auto;"><%= excerpts[key] %></pre>
                </div>
                <% } %>
            <% }); %>
            <% if (!Object.values(excerpts).some(Boolean)) { %>
                <p class="text-muted mb-0">No OCR text stored yet. Use Re-run AI analysis after documents are uploaded.</p>
            <% } %>
        </div>
    </div>

    <div class="card shadow-sm border-0 mt-4">
        <div class="card-header bg-white"><strong>Uploaded documents</strong></div>
        <div class="card-body d-flex flex-wrap gap-2">
            <% const docs = donor.medicalReports || {}; %>
            <% if (docs.bloodGroupReportUrl) { %><a class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener" href="<%= docUrl(docs.bloodGroupReportUrl) %>">Blood group report</a><% } %>
            <% if (docs.bloodTestReportUrl) { %><a class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener" href="<%= docUrl(docs.bloodTestReportUrl) %>">Blood test report</a><% } %>
            <% if (docs.fitnessCertificateUrl) { %><a class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener" href="<%= docUrl(docs.fitnessCertificateUrl) %>">Fitness certificate</a><% } %>
            <% if (docs.identityProofUrl) { %><a class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener" href="<%= docUrl(docs.identityProofUrl) %>">Identity proof</a><% } %>
        </div>
    </div>
</div>

<script>
document.getElementById('reanalyzeBtn')?.addEventListener('click', async function () {
    const btn = this;
    btn.disabled = true;
    btn.textContent = 'Analyzing…';
    try {
        const resp = await fetch('/ai/analyze-medical-report', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ donorId: '<%= donor._id %>', bloodGroup: '<%= donor.bloodGroup %>' }),
        });
        const data = await resp.json();
        if (!resp.ok || !data.ok) throw new Error(data.error || 'Analysis failed');
        window.location.reload();
    } catch (err) {
        alert(err.message || 'Could not re-run analysis');
        btn.disabled = false;
        btn.textContent = 'Re-run AI analysis';
    }
});
if (typeof lucide !== 'undefined') lucide.createIcons();
</script>
</body>
</html>

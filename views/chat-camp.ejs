<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chat — RaktaSetu Camp</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/admin-ui.css" rel="stylesheet">
    <link href="/css/camp-ui.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/socket.io/socket.io.js"></script>
</head>
<body class="admin-shell cp-shell">
<nav class="navbar navbar-dark" style="background:#5b21b6">
    <div class="container-fluid px-3">
        <a class="navbar-brand" href="/dashboard">🩸 RaktaSetu Camp</a>
        <a href="/messages" class="btn btn-light btn-sm">Inbox</a>
    </div>
</nav>
<div class="container py-4">
    <div class="d-flex align-items-center gap-3 mb-3">
        <%- include('partials/shared/card-avatar', { contactUser: otherUser, cardAvatarClass: 'chat-header-avatar' }) %>
        <div><h4 class="mb-0"><%= otherUser.name %></h4><small class="text-muted text-capitalize"><%= otherUser.role %> · <%= otherUser.city %></small><span id="chatPresenceStatus" class="chat-presence is-offline d-block mt-1">Offline</span></div>
        <% if (otherUser.phone) { %><a class="btn btn-outline-primary btn-sm ms-auto" href="tel:<%= otherUser.phone %>">Call</a><% } %>
    </div>
    <div class="border rounded p-3 bg-white" id="chatBox" style="min-height:50vh;max-height:55vh;overflow-y:auto">
        <% (messages || []).forEach(function(m) { const isMe = m.from.toString() === user._id.toString(); %>
        <div class="d-flex mb-2 <%= isMe ? 'justify-content-end' : 'justify-content-start' %>">
            <div class="rounded px-3 py-2 <%= isMe ? 'text-white' : 'bg-light' %>" style="<%= isMe ? 'background:#7c3aed' : '' %>"><%= m.text %><div class="small opacity-75 text-end"><%= new Date(m.createdAt).toLocaleTimeString() %></div></div>
        </div>
        <% }); %>
    </div>
    <form id="chatForm" class="mt-3 d-flex gap-2"><input id="chatInput" class="form-control" maxlength="2000" required placeholder="Type a message…"><button class="btn btn-primary" style="background:#7c3aed;border-color:#6d28d9">Send</button></form>
</div>
<script>window.__CHAT__ = { conversationId: "<%= conversation._id %>", otherUserId: "<%= otherUser._id %>", currentUserId: "<%= user._id %>" };</script>
<script src="/js/chat-presence.js"></script>
<script src="/js/chat.js"></script>
<style>.chat-header-avatar{width:48px;height:48px;border-radius:14px;overflow:hidden;background:linear-gradient(135deg,#a78bfa,#6d28d9);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800}.chat-header-avatar .card-avatar-img{width:100%;height:100%;object-fit:cover}.chat-presence{display:inline-flex;align-items:center;gap:6px;font-size:.78rem;font-weight:600}.chat-presence::before{content:'';width:8px;height:8px;border-radius:50%;flex-shrink:0}.chat-presence.is-online{color:#16a34a}.chat-presence.is-online::before{background:#22c55e;box-shadow:0 0 0 2px rgba(34,197,94,.25)}.chat-presence.is-offline{color:#64748b}.chat-presence.is-offline::before{background:#94a3b8}</style>
</body>
</html>

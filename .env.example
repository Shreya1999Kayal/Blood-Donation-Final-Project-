# Copy to .env locally, or set each variable in Render → Environment (do not commit .env)

PORT=3000

# Database (MongoDB Atlas connection string)
MONGODB_URI=

# Auth — use long random strings in production
JWT_SECRET=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_AUTH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7
SESSION_SECRET=

# Your live site URL (no trailing slash)
APP_URL=https://your-app.onrender.com

# --- Email: use SendGrid API OR SMTP, not both ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Leave SMTP empty if using SendGrid API above
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# --- Phone OTP (Twilio) — required for SMS on production ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SMS_LOG_OTP=false

# Optional
OPENAI_API_KEY=
GEMINI_API_KEY=
ADMIN_ALERT_EMAIL=

CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

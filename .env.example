PORT=3000
MONGO_URL=mongodb://127.0.0.1:27017/blood_donation
# Legacy alias (optional if MONGO_URL is set)
MONGODB_URI=mongodb://127.0.0.1:27017/blood_donation
JWT_SECRET=change_me_legacy_fallback
JWT_ACCESS_SECRET=change_me_access_secret_long_random
JWT_REFRESH_SECRET=change_me_refresh_secret_long_random
JWT_AUTH_SECRET=change_me_high_level_auth_secret_long_random
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7
OPENAI_API_KEY=your_openai_api_key_here
# Google Gemini — RaktaSetu help chatbot (/ai/help) + medical OCR analysis
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: skip Gemini for help chat during demo / quota issues (uses built-in FAQ)
HELP_CHAT_LOCAL_ONLY=true
# Optional model override (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash
# Optional OpenAI fallback for medical report analysis (/ai/analyze-medical-report)
# OPENAI_MODEL=gpt-4o-mini
# Optional extra email for critical emergency alerts (also sent to all admin users)
# ADMIN_ALERT_EMAIL=admin@example.com
SESSION_SECRET=change_me_session_secret

# Email / OTP verification
# Gmail example: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="RaktaSetu <your.email@gmail.com>"
APP_URL=http://localhost:3000

# Twilio — phone OTP during registration (all roles)
# Create account at https://www.twilio.com — use a trial or purchased SMS-enabled number
# Leave as placeholders below to print OTP in the server terminal instead of sending SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
# Optional: force OTP in terminal (default: on when NODE_ENV is not production)
# SMS_LOG_OTP=true

# Cloudinary (documents + profile photos)
# Only these three keys are required. CLOUDINARY_FOLDER is optional (defaults to rakta-setu/profiles).
# In Cloudinary dashboard: Settings → Security → enable "Allow delivery of PDF and ZIP files"
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional — profile photos upload to {CLOUDINARY_FOLDER or rakta-setu}/profiles
# CLOUDINARY_FOLDER=rakta-setu

# Razorpay — KEY_ID and KEY_SECRET must be from the same Razorpay account (Test mode keys start with rzp_test_)
# Test checkout: UPI → success@razorpay (no OTP). Skipping card OTP fails in test mode.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
# Optional — leave empty to verify payments via /payment/verify only (no webhook)
# RAZORPAY_WEBHOOK_SECRET=
